|mat x y dir pArch line vent aux contx conty cantconfig fondo|"Instrucciones"Instrucciones cantconfig: 3."Debug"fondo:= Morph new.vent:= OSWindowWorldMorph new."Abrir un documento"dir:= FileSystem disk workingDirectory.pArch:= (dir,'\Naves.csv') readStream."config aleatoria"((0 to: ((Instrucciones cantconfig)-1)) atRandom) timesRepeat: [ 	(7) timesRepeat: [ line:= pArch nextLine. ] 	].conty:= 0.(6) timesRepeat: [					line:= pArch nextLine.					conty:= conty + 1.					contx:= 0.					line do: [ :i| 						contx:= contx + 1.						aux:= Nave new.						fondo addMorph: aux.						aux position: (((aux width)*contx+0.1)@((aux height)*conty+0.1)).						(i = $■) ifTrue: [aux delete].						(i = $⌂) ifTrue: ["nada"].						(i = $○) ifTrue: [aux color: Color red].						(i = $▲) ifTrue: [aux color: Color pink].						(i = $☼) ifTrue: [aux color: Color green].								].					Transcript cr.					].				line:= pArch nextLine.				pArch close.				fondo openInWorld: vent.				fondo submorphsDo: [ :i | Transcript show: (i color); cr ].				vent open.									