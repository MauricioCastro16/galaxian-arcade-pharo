|font tMorph bMorph|font := LogicalFont familyName: '' pointSize: 80.    tMorph := StringMorph new.    tMorph        contents: 'Hello World';        font: (LogicalFont familyName: 'Arial' pointSize: 80);        emphasis: TextEmphasis bold emphasisCode.    bMorph := Morph new        color: Color red;        addMorphBack: tMorph.        bMorph bounds:(tMorph fullBounds).    bMorph openInHand