|alto ancho color1 color2 fill planeta cuadrado1 cuadrado2|			planeta:= EllipseMorph new.		alto:= (Fondo alto / 3).		ancho:= (Fondo alto / 3).		planeta extent: (ancho @ alto).		planeta fillStyle isGradientFill ifTrue:[^planeta]. "Already done"		color1 := Color yellow.		color2 := Color lightYellow.		fill := GradientFillStyle ramp: {0.0 -> color1. 1.0 -> color2}.		fill origin: planeta topLeft.		fill direction: 0 @ planeta bounds extent y.		fill normal: planeta bounds extent x @ 0.		fill radial: false.		planeta fillStyle: fill.		planeta borderColor: (planeta color alpha: 0).				cuadrado1:= PolygonMorph new.		cuadrado1 diamondOval.		cuadrado1 extent: planeta extent * 1.74.		cuadrado1 center: planeta center.		cuadrado1 fillStyle isGradientFill ifTrue:[^cuadrado1]. "Already done"		color1 := Color yellow.		color2 := Color lightYellow.		fill := GradientFillStyle ramp: {0.0 -> color1. 1.0 -> color2}.		fill origin: planeta topLeft.		fill direction: 0 @ planeta bounds extent y.		fill normal: planeta bounds extent x @ 0.		fill radial: false.		cuadrado1 fillStyle: fill.		cuadrado1 borderColor: (cuadrado1 color alpha: 0).		planeta addMorph: cuadrado1.		