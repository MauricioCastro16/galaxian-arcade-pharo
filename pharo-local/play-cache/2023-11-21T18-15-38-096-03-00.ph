|dir pArch lectura line max vent intro texto|	"Abrir el documento para ver los puntajes"	dir:= FileSystem disk workingDirectory.	lectura:= (dir,'\Score.csv') readStream.	pArch:= (dir,'\Score.csv') writeStream.	line:= ''.	vent:= OSWindowWorldMorph new.	[lectura atEnd] whileFalse: [		line:= line, lectura nextLine.	].	pArch nextPutAll: line, 'AGM ', Instrucciones score asString, ';'.	pArch close. 