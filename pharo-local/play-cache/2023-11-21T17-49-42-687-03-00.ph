|dir pArch line max score auxnum posicion|	"Abrir el documento para ver los puntajes"	dir:= FileSystem disk workingDirectory.	pArch:= (dir,'\Score.csv') readStream.	max:= 0.	score:= OrderedCollection new.	line:= pArch nextLine.	(line) ifNil: [line:= ''] ifNotNil: [line:= line substrings: ';'].	1 to:(line size) do: [ :i|		(max < (((line at: i) substrings) at: 2) asNumber) ifTrue: [ 			max:=  (((line at: i) substrings) at: 2) asNumber.			]	].	(line) sort: [:a :b | (((a substrings) at: 2) asNumber) >= (((b substrings) at: 2) asNumber)].	1 to: 10 do: [ :i | 		(i > (line size)) ifTrue: [ 								(i = 10) ifTrue: [ posicion:= i asString]											ifFalse: [ posicion:= '0', i asString].								score add: posicion, '- 0000000 - - - - XXX' 								]								ifFalse: [									auxnum:= ''.									(i = 10) ifTrue: [ posicion:= i asString]											ifFalse: [ posicion:= '0', i asString].									(7 - (((line at: i) substrings) at: 2) size) timesRepeat: [										auxnum:= auxnum, '0'										].									auxnum:= auxnum, (((line at: i) substrings) at: 2) asString.									score add: posicion, '- ', auxnum ,' - - - - ', (((line at: i) substrings) at: 1) asString 									].		 ].	^score