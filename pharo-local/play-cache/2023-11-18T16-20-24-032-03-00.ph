|x y z vent color1 color2 fill|x:= EllipseMorph new.x extent: (200 @ 200).x color: Color red darker darker darker darker darker darker darker.x borderColor: x color darker.	y := Color red darker darker darker darker darker darker darker.	z := Color red darker darker darker darker darker.	fill := GradientFillStyle ramp: {0.0 -> color1. 1.0 -> color2}.	fill origin: x topLeft.	fill direction: 0 @ x bounds extent y.	fill normal: x bounds extent x @ 0.	fill radial: false.	x fillStyle: fill.vent:= OSWindowWorldMorph new.x openInWorld: vent.vent open.