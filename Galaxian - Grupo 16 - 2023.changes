 @ (Fondo alto / 100))).	(self owner) submorphsDo: [ :i | "Pregunta por todos los submorphs del fondo"		(i class = Enjambre) ifTrue: [  "Detecta al enjambre"			i submorphsDo: [:j | 				(j class = Nave) ifTrue: [ "busca las naves"				(self intersects: j bounds) ifTrue: [ "Detecta si la bala está en contacto con una nave"					(j color = Color orange) ifTrue: [ 						Instrucciones score: (Instrucciones score + 10)						 ].					(j color = Color red) ifTrue: [ 						Instrucciones score: (Instrucciones score + 20)						 ].					(j color = Color pink) ifTrue: [ 						Instrucciones score: (Instrucciones score + 50)						 ].					(j color = Color green) ifTrue: [ 						Instrucciones score: (Instrucciones score + 100) "Según el color de la nave, suma distinto puntaje"						 ].					explosion:= Explosion new. "Crea una explosión"					(j owner) addMorph: explosion. "Le asigna al fondo"					explosion center: j center. 					Protagonista bandBullet: true. "Permite que el protagonista vuelva a disparar"					j delete.   "Mata a la nave"					self delete. "Se elimina"					(j check) ifNotNil: [ j check delete ] "Si existe un checkpoint (es decir, la nave atacó y no se repuso), también tiene que borrarlo"					] ] 				] 			] 		].	(((self position) y) < (0)) ifTrue: [ self delete. Protagonista bandBullet: true ]. "Pregunto si salió po arriba de la pantalla, se elimina y el protagonista puede volver a disparar"		! !----SNAPSHOT----2023-11-21T17:45:58.1-03:00 21-11.image priorSource: 1115705!----SNAPSHOT----2023-11-21T17:47:23.803-03:00 21-11.image priorSource: 1117373!----QUIT----2023-11-21T17:47:26.723-03:00 21-11.image priorSource: 1117452!----SNAPSHOT----2023-11-21T18:13:39.759-03:00 21-11.image priorSource: 1117533!----QUIT----2023-11-21T18:13:42.611-03:00 21-11.image priorSource: 1117610!----SNAPSHOT----2023-11-21T20:59:11.293-03:00 21-11.image priorSource: 1117691!----SNAPSHOT----2023-11-22T02:18:13.019-03:00 21-11.image priorSource: 1117768!----QUIT----2023-11-22T02:18:17.178-03:00 21-11.image priorSource: 1117849!----QUIT----2023-11-22T23:44:30.675-03:00 21-11.image priorSource: 1117930!Morph subclass: #Enjambre	instanceVariableNames: 'direccion posicionando mensaje velocidad'	classVariableNames: ''	package: 'Jueguito'!!Enjambre methodsFor: 'initialization' stamp: 'Anonymous 11/22/2023 23:53' prior: 34590703!initialize	|dir pArch line aux contx conty|	super initialize.	self startStepping.	self extent: (((Fondo ancho / 16)*10) @ ((Fondo alto / 24)*6)). "Setear tamaño para cualquier display"	direccion:= 'der'. "Arranca yendo para la derecha"	posicionando:= true.	velocidad:= 60.		"Abrir el documento de la configuración de las naves"	dir:= FileSystem disk workingDirectory.	pArch:= (dir,'\Naves.csv') readStream.	"config aleatoria"	((0 to: ((Instrucciones cantconfig)-1)) atRandom) timesRepeat: [ "Saltea las primeras n-1 configuraciones"		(7) timesRepeat: [ line:= pArch nextLine. ] 		].		conty:= -1.	(6) timesRepeat: [					line:= pArch nextLine.					conty:= conty + 1.					contx:= -1.					line do: [ :i| 						contx:= contx + 1.						aux:= Nave new.						aux position: (((Fondo alto / 16)*contx) @ ((Fondo alto / 24)*conty)). "Recorrer como una matriz"						self addMorph: aux.						(i = $■) ifTrue: [aux delete]. "Es aire, lo borra"						(i = $⌂) ifTrue: [aux color: Color orange].						(i = $○) ifTrue: [aux color: Color red].						(i = $▲) ifTrue: [aux color: Color pink].						(i = $☼) ifTrue: [aux color: Color green]. "Patron de las naves, según el color, indica las diferentes naves"								].					].				pArch close.! !!Enjambre methodsFor: 'stepping and presenter' stamp: 'Anonymous 11/22/2023 23:53' prior: 33761691!stepTime	^velocidad! !!Enjambre methodsFor: 'stepping and presenter' stamp: 'Anonymous 11/22/2023 23:54' prior: 34595124!step	|aux bullet correcty|		(posicionando) ifTrue: [		correcty:= ((((self owner) top + ((self height)/2))- self position y) / (Fondo ancho/30) ).		self position: self position + (0 @ correcty). "Corrige su posición respecto al checkpoint"		((self position y) truncated) = (((self owner) top + ((self height)/2)) truncated) ifTrue: [posicionando := false. mensaje delete] "Verifica que llegó a su posición"		].		(((self position x - (self owner) left))abs < (Fondo ancho / 20)) ifTrue: [ direccion:= 'der' ]. "compara posición del enjambre con la parte izquierda del fondo, y da un margen de error"	(((self position x - ((self owner) right - self width)))abs < (Fondo ancho / 20)) ifTrue: [ direccion:= 'izq' ]. "idem pero con la parte derecha del fondo"		(direccion = 'der') ifTrue: [ self position: (self position + (((self position x - ((self owner) right-self width))abs / (Fondo ancho / 40)) @ 0)) ]. "Mientras más cerca esté del borde, se mueva más lento"	(direccion = 'izq') ifTrue: [ self position: (self position - (((self position x - ((self owner) left))abs / (Fondo ancho / 40)) @ 0)) ]. "Idem pero para la izquierda"		(self submorphs = { }) ifTrue: [self delete. Fondo enjambremuerto: true. Instrucciones vidas: (Instrucciones vidas + 1).]. "Si no quedan naves, se da como enjambre muerto, se borra y avisa a Fondo. Además da una vida"		((1 to: 1+(((self submorphs) size)/2) abs) atRandom = 1) ifTrue: [ "Hace un random para entrar en la función de enojar naves enemigas"		self submorphsDo: [ :i | ((1 to: (1 + (self submorphs) size) ) atRandom = 1) ifTrue: [ "Random para c/u de las naves"				(i class = Nave) ifTrue: [ "Se aclara que sea una Nave porque puede haber checkpoints en el enjambre"				(i enojado or: (i reposicion)) ifFalse: [ "Para que no se enoje una nave que ya está enojado ni tampoco una nave que se está reposicionando"				i enojado: true.  "enoja"				aux:= Checkpoint new. "Este checkpoint crea un objeto invisible para que, cuando la nave baje por la pantalla, pueda volver a su lugar de origen"				aux position: i position.				aux extent: i extent. "Idem forma y posición de la nave saliente"				self addMorph: aux. "Lo añado al enjambre"				i check: aux. "Hace una agregación entre la nave y el checkpoint"				] ] ] ].		 ].	((1 to: 1+(((self submorphs) size)/8) abs) atRandom = 1) ifTrue: [ "Random para entrar al proceso de lanzar una bala"		self submorphsDo: [ :i | ((1 to: (1 + (((self submorphs) size)) abs )) atRandom = 1) ifTrue: [ "Random para que una nave tire una bala"				(i class = Nave) ifTrue: [ "Nuevamente se hace la comparación para que no sea un checkpoint"				((1 to: 5) atRandom = 1) ifTrue: [ bullet:= BalaEnemiga new. bullet position: i position. (self owner) addMorph: bullet ]. "Nuevo random para bajar la probabilidad de bala, se agrega la bala al fondo"				] ] ] ].	(((1 to: 3000) atRandom = 1) and: (velocidad > 20) ) ifTrue: [ velocidad:= velocidad + 1. ]	! !----SNAPSHOT----2023-11-22T23:54:11.858-03:00 22-11.image priorSource: 1118007!!Enjambre methodsFor: 'stepping and presenter' stamp: 'Anonymous 11/22/2023 23:54' prior: 34674244!step	|aux bullet correcty|		(posicionando) ifTrue: [		correcty:= ((((self owner) top + ((self height)/2))- self position y) / (Fondo ancho/30) ).		self position: self position + (0 @ correcty). "Corrige su posición respecto al checkpoint"		((self position y) truncated) = (((self owner) top + ((self height)/2)) truncated) ifTrue: [posicionando := false. mensaje delete] "Verifica que llegó a su posición"		].		(((self position x - (self owner) left))abs < (Fondo ancho / 20)) ifTrue: [ direccion:= 'der' ]. "compara posición del enjambre con la parte izquierda del fondo, y da un margen de error"	(((self position x - ((self owner) right - self width)))abs < (Fondo ancho / 20)) ifTrue: [ direccion:= 'izq' ]. "idem pero con la parte derecha del fondo"		(direccion = 'der') ifTrue: [ self position: (self position + (((self position x - ((self owner) right-self width))abs / (Fondo ancho / 40)) @ 0)) ]. "Mientras más cerca esté del borde, se mueva más lento"	(direccion = 'iz