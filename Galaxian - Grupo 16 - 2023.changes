se. ].	((1 to: 500) atRandom = 1) ifTrue: [ candash:= true. self submorphsDo: [ :i | i color: (i color alpha: 1) ] ]! !----SNAPSHOT----2023-11-17T23:27:26.433-03:00 17-11 ver2.image priorSource: 496336!----SNAPSHOT----2023-11-17T23:30:09.214-03:00 17-11 ver2.image priorSource: 498465!----SNAPSHOT----2023-11-17T23:32:56.496-03:00 17-11 ver2.image priorSource: 498550!!Fondo methodsFor: 'initialization' stamp: 'Anonymous 11/17/2023 23:38' prior: 33702191!crearEstrellas	|x y star|	x:= ancho / 30. 	y:= alto / 30. "Matrix 30x30"	0 to: 29 do: [  :i|		0 to: 29 do: [ :j|			((1 to: 10) atRandom = 1) ifTrue: [ 					star:= Estrella new.					self addMorph: star.					star position: (x * i) @ (y * j).				 ]			 ]		]! !!Fondo methodsFor: 'initialization' stamp: 'Anonymous 11/17/2023 23:38' prior: 33845585!initialize	|prota score|	super initialize. "superinicializamos la forma"	self startStepping. "inicializamos los pasos"	enjambremuerto:= true.	ancho:= Display height.	alto:= Display height. "Le asignamos el tamaño de la ejecución del programa para que este no varíe durante la ejecución"	self extent: (ancho)@(alto). "Tamaño del fondo"	self color: Color black.	self crearEstrellas. "Importa el orden para que las estrellas estén de fondo"	prota:= Protagonista new.	prota position: (ancho/2)@(alto-(prota bottom * 2)).	self addMorph: prota.	score:= Score new.	self addMorph: score.! !!Fondo methodsFor: 'initialization' stamp: 'Anonymous 11/17/2023 23:38' prior: 34053600!initialize	|prota score|	super initialize. "superinicializamos la forma"	self startStepping. "inicializamos los pasos"	enjambremuerto:= true.	ancho:= Display height.	alto:= Display height. "Le asignamos el tamaño de la ejecución del programa para que este no varíe durante la ejecución"	self extent: (ancho)@(alto). "Tamaño del fondo"	self color: Color black.	self crearEstrellas. "Importa el orden para que las estrellas estén de fondo"	prota:= Protagonista new. "Nave principal"