 position: self position + (((self position x - ((self owner) right-self width))abs / (Fondo ancho / 50)) @ 0)]]. "Movimiento relativo para la derecha"keyValue = 97 "Tecla A"ifTrue: [ (lockmov) ifFalse: [self position: self position - (((self position x - ((self owner) left))abs / (Fondo ancho / 50)) @ 0)]]. "Movimiento relativo para la izquierda"keyValue = 32 "Espacio"ifTrue: [ (bandBullet) ifTrue: [ "Se fija si puede disparar"		bullet:= Bala new. "Crea una nueva bala"		randombala:= (1 to: 3) atRandom. "Randomiza de dónde sale la bala"		(randombala = 1) ifTrue: [bullet center: self center - (0@(self height*0.1))].		(randombala = 2) ifTrue: [bullet position: self position + ((self width * 0.3)@(self height*0.1))].		(randombala = 3) ifTrue: [bullet position: self position + ((self width * 0.7)@(self height*0.1))].		(self owner) addMorph: bullet. "Añade la bala al fondo"		bandBullet:= false "No permite que siga disparando"		] ].keyValue = 101 "Dash, hacia la derecha"ifTrue: [ (candash and: (lockmov) not) ifTrue: [ "Se fija si puede dashear y si no tiene lockeado el movimiento"	colorbase:= Color lightGray. "Para que el titileo de la invulnerabilidad sea del color gris"	self color: Color lightGray. 	lockmov:= true. "Lockea el movimiento"	invulnerable:=true. "Lo hace invulnerable"	dash:= 20. "Pone las repeticiones de movimiento del dash"	candash:= false. "Impide que vuelva a dashear"	self submorphsDo: [:i | i color: (i color alpha: 0)]]]. "Pone el fuego que representa el dash en invisible"keyValue = 113ifTrue: [ (candash and: (lockmov) not) ifTrue: [	colorbase:= Color lightGray.	self color: Color lightGray.	lockmov:= true.	invulnerable:=true.	dash:= -20. "El número negativo indica el dasheo para el otro lado"	candash:= false.	self submorphsDo: [:i | i color: (i color alpha: 0)]]]! !----SNAPSHOT----2023-11-18T00:39:11.008-03:00 17-11 ver2.image priorSource: 548194!!Explosion methodsFor: 'initialization' stamp: '3 11/18/2023 00:39' prior: 34093696!initialize	|colorselector|	super initialize.	self startStepping.	momento:= 'expansion'.	colorselector:= (1 to: 20) atRandom. "Permite que las explosiones tengan colores diferentes"	((1 to: 8) rangeIncludes: colorselector) ifTrue: [ self color: Color yellow ].	((9 to: 15) rangeIncludes: colorselector) ifTrue: [ self color: Color orange ].	((16 to: 19) rangeIncludes: colorselector) ifTrue: [ self color: Color lightYellow].	(colorselector = 20) ifTrue: [ self color: Color red darker ]. "La explosión roja sea más rara"	self extent: (Fondo alto / 64) @ (Fondo ancho / 64) ! !!Protagonista methodsFor: 'initialization' stamp: '3 11/18/2023 00:40' prior: 34102074!initialize	|fuego|	super initialize.	self startStepping.	self extent: (Fondo ancho/20) @ (Fondo alto/25).	bandBullet:= true.	invulnerable:= true. "invulnerabilidad por un tiempo pequeño"	dash:= 0.	colorbase:= Color blue.	lockmov:= false.	fuego:= Morph new.	fuego extent: ((self extent)/6.1).	fuego color: Color orange.	fuego center: self center.	fuego position: self position + ((self width*0.41)@(self height * 0.9)).	self addMorph: fuego.	candash:= true.	Transcript show: self extent.	! !!Protagonista methodsFor: 'initialization' stamp: '3 11/18/2023 00:40' prior: 34105658!initialize	|fuego|	super initialize.	self startStepping.	self extent: (Fondo ancho/20) @ (Fondo alto/25).	bandBullet:= true.	invulnerable:= true. "invulnerabilidad por un tiempo pequeño"	dash:= 0.	colorbase:= Color blue.	lockmov:= false.	fuego:= Morph new. "Este fuego representa el poder hacer un dash"	fuego extent: ((self extent)/6.1).	fuego color: Color orange.	fuego center: self center.	fuego position: self position + ((self width*0.41)@(self height * 0.9)).	self addMorph: fuego.	candash:= true.	Transcript show: self extent.	! !----SNAPSHOT----2023-11-18T00:41:15.257-03:00 17-11 ver2.image priorSource: 550378!!Protagonista methodsFor: 'stepping and presenter' stamp: '3 11/18/2023 00:43'