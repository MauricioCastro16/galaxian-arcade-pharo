tepping and presenter' stamp: 'Anonymous 11/17/2023 18:40' prior: 33880739!step	|correctx correcty|	(((1 to: 50) atRandom = 1) and: (velocidad > 20)) ifTrue: [ velocidad:= velocidad - 1].	 (enojado) ifTrue: [ 		self position: self position + (0 @ 5).		((1 to: 2) atRandom = 1) ifTrue: [ 		correctx:= (Protagonista posx - ((self owner) right-self width)abs / (Fondo ancho/30) ).		self position: self position + (correctx @ 0).		]].	(self position y > Fondo alto) ifTrue: [ self position: ((check position x) @ 0). enojado:= false. reposicion:= true].	(reposicion) ifTrue: [		correctx:= ((check position x - self position x) / (Fondo ancho/30)  ).		correcty:= ((check position y - self position y) / (Fondo ancho/30) ).		self position: self position + (correctx @ correcty).		((self position y) truncated) = ((check position y) truncated) ifTrue: [reposicion:= false. check delete]		].! !----SNAPSHOT----2023-11-17T18:40:16.073-03:00 17-11 ver2.image priorSource: 366239!!Nave methodsFor: 'stepping and presenter' stamp: 'Anonymous 11/17/2023 18:40' prior: 33920853!step	|correctx correcty|	(((1 to: 50) atRandom = 1) and: (velocidad > 20)) ifTrue: [ velocidad:= velocidad - 1].	 (enojado) ifTrue: [ 		self position: self position + (0 @ 5).		((1 to: 2) atRandom = 1) ifTrue: [ 		correctx:= (Protagonista posx - self position x / (Fondo ancho/30) ).		self position: self position + (correctx @ 0).		]].	(self position y > Fondo alto) ifTrue: [ self position: ((check position x) @ 0). enojado:= false. reposicion:= true].	(reposicion) ifTrue: [		correctx:= ((check position x - self position x) / (Fondo ancho/30)  ).		correcty:= ((check position y - self position y) / (Fondo ancho/30) ).		self position: self position + (correctx @ correcty).		((self position y) truncated) = ((check position y) truncated) ifTrue: [reposicion:= false. check delete]		].! !!Nave methodsFor: 'stepping and presenter' stamp: 'Anonymous 11/17/2023 18:41' prior: 33921861!step	|corre