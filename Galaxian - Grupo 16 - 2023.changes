.618-03:00 Pharo 11.0 - 64bit (stable).image priorSource: 60622!!Nave methodsFor: 'drawing' stamp: 'Anonymous 11/14/2023 19:28' prior: 33587679!drawOn: aCanvas         | shipWidth wingWidth wingHeight bodyHeight bodyWidth bodyTop bodyLeft |        shipWidth := self bounds width.        wingWidth := shipWidth * 0.4.        wingHeight := 5.        bodyWidth := shipWidth * 0.3.        bodyHeight := 10.        bodyTop := self bounds top - bodyHeight.        bodyLeft := self bounds left + (shipWidth - bodyWidth) // 2.        aCanvas            fillRectangle: (bodyLeft@bodyTop corner: (bodyLeft + bodyWidth)@(bodyTop - bodyHeight))            color: self color.        aCanvas            fillRectangle: (self bounds left@bodyTop corner: (self bounds right)@(bodyTop - wingHeight))            color: self color.! !!Nave methodsFor: 'drawing' stamp: 'Anonymous 11/14/2023 19:30' prior: 33616679!drawOn: aCanvas         | wingWidth wingHeight bodyWidth bodyHeight bodyTop bodyLeft |        wingWidth := self width * 0.4.        wingHeight := 5.        bodyWidth := self width * 0.3.        bodyHeight := 10.        bodyTop := self height - bodyHeight.        bodyLeft := (self width - bodyWidth) // 2.        aCanvas            fillRectangle: (bodyLeft@bodyTop corner: (bodyLeft + bodyWidth)@(bodyTop - bodyHeight))            color: self color.        aCanvas            fillRectangle: (0@bodyTop corner: self width@(bodyTop - wingHeight))            color: self color.        aCanvas            fillRectangle: (bodyLeft@bodyTop corner: (bodyLeft + bodyWidth)@(bodyTop - bodyHeight))            color: self color.        aCanvas            fillRectangle: (self bounds left@bodyTop corner: (self bounds right)@(bodyTop - wingHeight))            color: self color.! !!Nave methodsFor: 'drawing' stamp: 'Anonymous 11/14/2023 19:31' prior: 33617454!drawOn: aCanvas         | wingWidth wingHeight bodyWidth bodyHeight bodyTop bodyLeft |        wingWidth := self width * 0.4.        wingHeight := 5.        bodyWidth := self width * 0.3.        bodyHeight := 10.        bodyTop := self height - bodyHeight.        bodyLeft := (self width - bodyWidth) // 2.! !!Nave methodsFor: 'drawing' stamp: 'Anonymous 11/14/2023 19:32' prior: 33618435!drawOn: aCanvas| crossHeight crossWidth horizontalBar verticalBar |crossHeight := self height / 3.crossWidth := self width / 3.horizontalBar := self bounds insetBy: 0 @ crossHeight.verticalBar := self bounds insetBy: crossWidth @ 0.aCanvas fillRectangle: horizontalBar color: self color.aCanvas fillRectangle: verticalBar color: self color! !!Nave methodsFor: 'drawing' stamp: 'Anonymous 11/14/2023 19:33' prior: 33618839!drawOn: aCanvas| crossHeight crossWidth horizontalBar verticalBar |crossHeight := self height / 3.crossWidth := self width / 3.horizontalBar := self bounds insetBy: 1 @ crossHeight.verticalBar := self bounds insetBy: crossWidth @ 0.aCanvas fillRectangle: horizontalBar color: self color.aCanvas fillRectangle: verticalBar color: self color! !!Nave methodsFor: 'drawing' stamp: 'Anonymous 11/14/2023 19:33' prior: 33619270!drawOn: aCanvas| crossHeight crossWidth horizontalBar verticalBar |crossHeight := self height / 3.crossWidth := self width / 3.horizontalBar := self bounds insetBy: 10 @ crossHeight.verticalBar := self bounds insetBy: crossWidth @ 0.aCanvas fillRectangle: horizontalBar color: self color.aCanvas fillRectangle: verticalBar color: self color! !!Nave methodsFor: 'drawing' stamp: 'Anonymous 11/14/2023 19:34' prior: 33619701!drawOn: aCanvas| crossHeight crossWidth horizontalBar verticalBar |crossHeight := self height / 3.crossWidth := self width / 3.horizontalBar := self bounds insetBy: 2 @ crossHeight.verticalBar := self bounds insetBy: crossWidth @ 10.aCanvas fillRectangle: horizontalBar color: self color.aCanvas fillRectangle: verticalBar color: self color! !!Nave methodsFor: 'drawing' stamp: 'Anonymous 11/