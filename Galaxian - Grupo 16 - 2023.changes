((1 to: 50) atRandom = 1) and: (dash = 0)) ifTrue: [ invulnerable := false. self color: Color blue ] "Saca la invulnerabilidad, excluyendo el dash"						]ifFalse: [	(self owner) submorphsDo: [ :i | 		(i class = Enjambre) ifTrue: [ 			i submorphsDo: [:j | 				(j class = Nave) ifTrue: [				(self intersects: j bounds) ifTrue: [ "Detecta la interacción de una nave enemiga con la nave propia"					explosion:= Explosion new.					fondo addMorph: explosion.					explosion center: self center.					auxpos:= self position.					(j check) ifNotNil: [ j check delete ].					j delete.					(Instrucciones vidas >= 0) ifTrue: [ self position: auxpos. Instrucciones vidas: (Instrucciones vidas - 1). invulnerable:= true]. "Si tiene más vidas, vuelve a spawnear"					(Instrucciones vidas < 0) ifTrue: [ (self owner) nroenjambre: 0. self delete. Juego abrirGameOver.].						]]]].		(i class = BalaEnemiga) ifTrue: [ "Detecta contacto con bala enemiga, idem anterior prácticamente"			(self intersects: i bounds) ifTrue: [					explosion:= Explosion new.					fondo addMorph: explosion.					explosion center: self center.					auxpos:= self position.					i delete.					(Instrucciones vidas >= 0) ifTrue: [ self position: auxpos. Instrucciones vidas: (Instrucciones vidas - 1). invulnerable:= true].					(Instrucciones vidas < 0) ifTrue: [ (self owner) nroenjambre: 0. self delete. Juego abrirGameOver. ]						]  			].			]].	(dash > 1) ifTrue: [ 		dash:= dash - 1.		self position: self position + (((self position x - ((self owner) right-self width))abs / (Fondo ancho / 50)) @ 0). "Repite n-1 veces un movimiento relativo para el dash"		 ].	(dash < (-1)) ifTrue: [ 		dash:= dash + 1.		self position: self position - (((self position x - ((self owner) left))abs / (Fondo ancho / 50)) @ 0). "Idem para el otro lado"		 ].	(dash = 1 or: (dash = (-1))) ifTrue: [ self color: Color blue. dash:=0. invulnerable:=false. colorbase:= Color blue. lockmov:= false. ]. "Pone el color a azul, el color del titileo a azul, saca la invulnerabilidad y el lockeo de movimiento y pone dash a 0"	((1 to: 500) atRandom = 1) ifTrue: [ candash:= true. self submorphsDo: [ :i | i color: (i color alpha: 1) ] ] "Probabilidad de poder volver a dashear"! !----SNAPSHOT----2023-11-23T14:20:38.174-03:00 22-11.image priorSource: 1239093!!Juego class methodsFor: 'as yet unclassified' stamp: 'Anonymous 11/23/2023 14:22' prior: 34793292!abrirGameOver	|gameover|	gameover:= GameOver new.   gameover center: fondo center.	gameover openInWorld: vent.	Instrucciones vidas: defaultVidas.	Instrucciones score: 0.	Estrella velocidad: 60.1.	Nave velocidad: 80.	Estrella canAccelerate: false.! !!GameOver methodsFor: 'as yet unclassified' stamp: 'Anonymous 11/23/2023 14:22' prior: 34791356!mostrarScore |dir pArch line auxnum posicion|	"Abrir el documento para ver los puntajes"	dir:= FileSystem disk workingDirectory.	pArch:= (dir,'\Score.csv') readStream.	score:= TextMorph new.	score contents: ''.	score centered.	line:= pArch nextLine.	(line) ifNil: [line:= ''] ifNotNil: [line:= line substrings: ';'].	(line) sort: [:a :b | (((a substrings) at: 2) asNumber) >= (((b substrings) at: 2) asNumber)].	1 to: 10 do: [ :i | 		(i > (line size)) ifTrue: [ 								(i = 10) ifTrue: [ posicion:= i asString]											ifFalse: [ posicion:= '0', i asString].								score contents: (score contents), '								', posicion, '-> 0000000 - - - - XXX'.								]								ifFalse: [									auxnum:= ''.									(i = 10) ifTrue: [ posicion:= i asString]											ifFalse: [ posicion:= '0', i asString].									(7 - (((line at: i) substrings) at: 2) size) timesRepeat: [										auxnum:= auxnum, '0'										].									auxnum:= auxnum, (((line at: i) substrings) at: 2) asString.									score contents: (score contents), '									', posicion, '-> ', auxnum ,' - - - - ', (((line at: i) substrings) at: 1) asString.									].		 ].	self addMorph: score.	score center: self center - ((self height / 20) @ 0).	continue actionSelector: #restart.! !!GameOver methodsFor: 'as yet unclassified' stamp: 'Anonymous 11/23/2023 14:24' prior: 34797278!mostrarScore |dir pArch line auxnum posicion|	"Abrir el documento para ver los puntajes"	dir:= FileSystem disk workingDirectory.	pArch:= (dir,'\Score.csv') readStream.	score:= TextMorph new.	score contents: ''.	score centered.	line:= pArch nextLine.	(line) ifNil: [line:= ''] ifNotNil: [line:= line substrings: ';'].	(line) sort: [:a :b | (((a substrings) at: 2) asNumber) >= (((b substrings) at: 2) asNumber)].	1 to: 10 do: [ :i | 		(i > (line size)) ifTrue: [ 								(i = 10) ifTrue: [ posicion:= i asString]											ifFalse: [ posicion:= '0', i asString].								score contents: (score contents), '								', posicion, '-> 0000000 - - - - XXX'.								]								ifFalse: [									auxnum:= ''.									(i = 10) ifTrue: [ posicion:= i asString]											ifFalse: [ posicion:= '0', i asString].									(7 - (((line at: i) substrings) at: 2) size) timesRepeat: [										auxnum:= auxnum, '0'										].									auxnum:= auxnum, (((line at: i) substrings) at: 2) asString.									score contents: (score contents), '									', posicion, '-> ', auxnum ,' - - - - ', (((line at: i) substrings) at: 1) asString.									].		 ].	self addMorph: score.	score center: self center.	continue actionSelector: #restart.! !!Juego methodsFor: 'initialization' stamp: 'Anonymous 11/23/2023 14:24' prior: 34631310!initialize	vent:= OSWindowWorldMorph new.	fondo:= Fondo new.	fondo center: (Display width / 2) @ (Display height / 2).	fondo openInWorld: vent.	defaultVidas:= Instrucciones vidas.	"(self class) abrirMenu."	(self class) abrirGameOver.	vent open.! !!GameOver methodsFor: 'as yet unclassified' stamp: 'Anonymous 11/23/2023 14:25' prior: 34798652!mostrarScore |dir pArch line auxnum posicion|	"Abrir el documento para ver los puntajes"	dir:= FileSystem disk workingDirectory.	pArch:= (dir,'\Scor