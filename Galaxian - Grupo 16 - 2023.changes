e: [ self position: ((self owner) right-self width) @ (self position y)]. "Si se sale de la pantalla, vuelve a una posición relativa tanto en x como en y"! !Estrella class removeSelector: #direccion:!!Fondo methodsFor: 'initialization' stamp: 'Anonymous 11/18/2023 20:40' prior: 34116761!initialize	|prota score planeta|	super initialize. "superinicializamos la forma"	self startStepping. "inicializamos los pasos"	enjambremuerto:= true.	ancho:= Display height.	alto:= Display height. "Le asignamos el tamaño de la ejecución del programa para que este no varíe durante la ejecución"	self extent: (ancho)@(alto). "Tamaño del fondo"	self color: Color black.	self crearEstrellas. "Importa el orden para que las estrellas estén de fondo"	planeta:= Planeta new.	self addMorph: planeta.	prota:= Protagonista new. "Nave principal"	prota position: (ancho/2)@(alto-(prota bottom * 2)). "Centrarla en su posición"	self addMorph: prota.	score:= Score new. "puntaje"	self addMorph: score.! !----SNAPSHOT----2023-11-18T20:40:59.325-03:00 18-11.image priorSource: 607089!!Planeta methodsFor: 'initialization' stamp: 'Anonymous 11/18/2023 20:42' prior: 34162066!initialize	|y z|	super initialize.	self extent: (200 @ 200).	self color: Color lightOrange darker darker darker darker darker darker darker.	self borderColor: self color darker.	y:= EllipseMorph new.	y extent: ((self width/0.6) @ (self height / 3)).	y center: self center.	self addMorph: y.	y color: Color orange darker darker darker darker darker darker darker.	y borderColor: y color.	z:= EllipseMorph new.	z extent: ((self width / 1.052) @ (self height / 3)).	z center: self center - (0 @ (self height / 7.5)).	z color: self color.	z borderColor: z color.	self addMorph: z.! !EllipseMorph subclass: #Planeta	instanceVariableNames: ''	classVariableNames: ''	package: 'Jueguito'!----SNAPSHOT----2023-11-18T20:43:05.903-03:00 18-11.image priorSource: 609702!!Planeta methodsFor: 'initialization' stamp: