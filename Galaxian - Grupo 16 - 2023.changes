lor white] 	ifFalse:[self color:self color darker].	(((1 to: 20) atRandom = 1) and: (velocidad > 1)) ifTrue: [ velocidad:= velocidad - 1 ]. "Las estrellas cada vez van más rápido"	((1 to: 20000) atRandom = 1) ifTrue: [ randdir:= (1 to: 3) atRandom. (randdir=1) ifTrue: [ direccion:= 'abajo' ]. (randdir=2) ifTrue: [ direccion:= 'diagonal' ]. (randdir=3) ifTrue: [ direccion:= 'izquierda' ]] "Cambia la dirección de las estrellas"! !----SNAPSHOT----2023-11-18T16:02:36.939-03:00 18-11.image priorSource: 583317!!Protagonista methodsFor: 'stepping and presenter' stamp: 'Anonymous 11/18/2023 16:03' prior: 34123488!step	|explosion auxpos|	posx:= (self position) x. "Esta información le sirve a las naves enemigas para trackear a la nave protagonista"	(invulnerable and: (dash = 0)) ifTrue: [ "Si está invulnerable, cada tiempo hay una probabilidad que deje de estarlo, además lo indica con un titileo"		(self color diff: Color black)<0.1 		ifTrue:[self color: colorbase] 		ifFalse:[self color:self color darker].		((1 to: 50) atRandom = 1) ifTrue: [ invulnerable := false. self color: Color blue ] "Saca la invulnerabilidad"						]ifFalse: [	(self owner) submorphsDo: [ :i | 		(i class = Enjambre) ifTrue: [ 			i submorphsDo: [:j | 				(j class = Nave) ifTrue: [				(self intersects: j bounds) ifTrue: [ "Detecta la interacción de una nave enemiga con la nave propia"					explosion:= Explosion new.					(self owner) addMorph: explosion.					explosion center: self center.					auxpos:= self position.					(j check) ifNotNil: [ j check delete ].					j delete.					self position: ((self owner) center x @ (self position y - (self owner height))). "En vez de destruir la nave, se recoloca en una posición fuera de la cámara, porque así no pierde el keyboardFocus"					(Instrucciones vidas > 0) ifTrue: [ self position: auxpos. Instrucciones vidas: (Instrucciones vidas - 1). invulnerable:= true]. "Si tiene más vidas, vuelve a spawnear"						]]]].		(i class = BalaEnemiga) ifTrue: [ "Detecta contacto con bala enemiga, idem anterior prácticamente"			(self intersects: i bounds) ifTrue: [					explosion:= Explosion new.					(self owner) addMorph: explosion.					explosion center: self center.					auxpos:= self position.					i delete.					self position: ((self owner) center x @ (self position y - (self owner height))).					(Instrucciones vidas > 0) ifTrue: [ self position: auxpos. Instrucciones vidas: (Instrucciones vidas - 1). invulnerable:= true].						]  			].			]].	(dash > 1) ifTrue: [ 		dash:= dash - 1.		self position: self position + (((self position x - ((self owner) right-self width))abs / (Fondo ancho / 50)) @ 0). "Repite n-1 veces un movimiento relativo para el dash"		 ].	(dash < (-1)) ifTrue: [ 		dash:= dash + 1.		self position: self position - (((self position x - ((self owner) left))abs / (Fondo ancho / 50)) @ 0). "Idem para el otro lado"		 ].	(dash = 1 or: (dash = (-1))) ifTrue: [ self color: Color blue. dash:=0. invulnerable:=false. colorbase:= Color blue. lockmov:= false. ]. "Pone el color a azul, el color del titileo a azul, saca la invulnerabilidad y el lockeo de movimiento y pone dash a 0"	((1 to: 500) atRandom = 1) ifTrue: [ candash:= true. self submorphsDo: [ :i | i color: (i color alpha: 1) ] ] "Probabilidad de poder volver a dashear"! !----SNAPSHOT----2023-11-18T16:03:25.502-03:00 18-11.image priorSource: 585074!!Protagonista methodsFor: 'stepping and presenter' stamp: 'Anonymous 11/18/2023 16:03' prior: 34139691!step	|explosion auxpos|	posx:= (self position) x. "Esta información le sirve a las naves enemigas para trackear a la nave protagonista"	(invulnerable and: (dash = 0)) ifTrue: [ "Si está invulnerable, cada tiempo hay una probabilidad que deje de estarlo sacando el dash, además lo indica con un titileo"		(self color diff: Color black)<0.1 		ifTrue:[self color: colorbase] 		ifFalse:[self color:self color darker].		((1 to: 50) atRandom = 1) ifTrue: [ invulnerable := false. self color: