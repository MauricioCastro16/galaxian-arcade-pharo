 1) ] ].		]. "Si se sale de la pantalla, vuelve a una posición relativa tanto en x como en y"! !!Planeta methodsFor: 'initialization' stamp: 'Anonymous 11/19/2023 13:54' prior: 34333432!initialize	|y z randomplanet fill color1 color2|	super initialize.	visible:= false.	randomplanet:= (1 to: 2) atRandom. "Elige un planeta de n planetas"	(randomplanet = 1) ifTrue: [		alto:= (Fondo alto / 3).		ancho:= (Fondo alto / 3) / 0.6.		self extent: (ancho * 0.6 @ alto).		color1 := Color lightOrange darker darker darker darker darker darker darker darker darker darker.		color2 := color1 darker darker darker.		fill := GradientFillStyle ramp: {0.0 -> color1. 1.0 -> color2}.		fill origin: self topLeft.		fill direction: 0 @ self bounds extent y.		fill normal: self bounds extent x @ 0.		fill radial: false.		self fillStyle: fill.		self borderColor: (self color alpha: 0).		y:= EllipseMorph new. "Anillo"		y extent: (ancho @ (self height / 3)).		y center: self center.		color1 := Color orange darker darker darker darker darker darker darker darker darker darker darker.		color2 := color1 darker.		fill := GradientFillStyle ramp: {0.0 -> color1. 1.0 -> color2}.		fill origin: y topLeft.		fill direction: 0 @ y bounds extent y.		fill normal: y bounds extent x @ 0.		fill radial: false.		y fillStyle: fill.		y borderColor: (y color alpha: 0).		self addMorph: y.		z:= EllipseMorph new. "Superposición para que parezca un anillo"		z extent: ((self width / 1.052) @ (self height / 3)).		z center: self center - (0 @ (self height / 7.5)).		color1 :=  Color lightOrange darker darker darker darker darker darker darker darker darker darker.		color2 := color1 darker darker darker.		fill := GradientFillStyle ramp: {0.0 -> color1.  1.0-> color2}.		fill origin: self topLeft.		fill direction: 0 @ self bounds extent y.		fill normal: self bounds extent x @ 0.		fill radial: false.		z fillStyle: fill.		z borderColor: (z color alpha: 0).		self addMorph: z.	].	(randompla