evamente se hace la comparación para que no sea un checkpoint"				((1 to: 5) atRandom = 1) ifTrue: [ bullet:= BalaEnemiga new. bullet position: i position. (self owner) addMorph: bullet ]. "Nuevo random para bajar la probabilidad de bala"				] ] ] ].	! !!Enjambre methodsFor: 'stepping and presenter' stamp: 'Anonymous 11/17/2023 23:55' prior: 34066694!step	|aux bullet|		(((self position x - (self owner) left))abs < (Fondo ancho / 20)) ifTrue: [ direccion:= 'der' ]. "compara posición del enjambre con la parte izquierda del fondo, y da un margen de error"	(((self position x - ((self owner) right - self width)))abs < (Fondo ancho / 20)) ifTrue: [ direccion:= 'izq' ]. "idem pero con la parte derecha del fondo"		(direccion = 'der') ifTrue: [ self position: (self position + (((self position x - ((self owner) right-self width))abs / (Fondo ancho / 40)) @ 0)) ]. "Mientras más cerca esté del borde, se mueva más lento"	(direccion = 'izq') ifTrue: [ self position: (self position - (((self position x - ((self owner) left))abs / (Fondo ancho / 40)) @ 0)) ]. "Idem pero para la izquierda"		(self submorphs = { }) ifTrue: [self delete. Fondo enjambremuerto: true. Instrucciones vidas: (Instrucciones vidas + 1)]. "Si no quedan naves, se da como enjambre muerto, se borra y avisa a Fondo. Además da una vida"		((1 to: 1+(((self submorphs) size)/2) abs) atRandom = 1) ifTrue: [ "Hace un random para entrar en la función de enojar naves enemigas"		self submorphsDo: [ :i | ((1 to: (1 + (self submorphs) size) ) atRandom = 1) ifTrue: [ "Random para c/u de las naves"				(i class = Nave) ifTrue: [ "Se aclara que sea una Nave porque puede haber checkpoints en el enjambre"				(i enojado or: (i reposicion)) ifFalse: [ "Para que no se enoje una nave que ya está enojado ni tampoco una nave que se está reposicionando"				i enojado: true.  "enoja"				aux:= Checkpoint new. "Este checkpoint crea un objeto invisible para que, cuando la nave baje por la pantalla, pueda volver a su lugar