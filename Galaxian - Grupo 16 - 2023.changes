ion' stamp: 'Anonymous 11/18/2023 00:16' prior: 34092334!initialize	|colorselector|	super initialize.	self startStepping.	momento:= 'expansion'.	colorselector:= (1 to: 26) atRandom. "Permite que las explosiones tengan colores diferentes"	((1 to: 8) rangeIncludes: colorselector) ifTrue: [ self color: Color yellow ].	((9 to: 15) rangeIncludes: colorselector) ifTrue: [ self color: Color orange ].	((16 to: 19) rangeIncludes: colorselector) ifTrue: [ self color: Color lightYellow].	(colorselector = 20) ifTrue: [ self color: Color red darker ]. "La explosión roja sea más rara"	self extent: (Fondo alto / 64) @ (Fondo ancho / 64)! !!Explosion methodsFor: 'initialization' stamp: 'Anonymous 11/18/2023 00:17' prior: 34093015!initialize	|colorselector|	super initialize.	self startStepping.	momento:= 'expansion'.	colorselector:= (1 to: 20) atRandom. "Permite que las explosiones tengan colores diferentes"	((1 to: 8) rangeIncludes: colorselector) ifTrue: [ self color: Color yellow ].	((9 to: 15) rangeIncludes: colorselector) ifTrue: [ self color: Color orange ].	((16 to: 19) rangeIncludes: colorselector) ifTrue: [ self color: Color lightYellow].	(colorselector = 20) ifTrue: [ self color: Color red darker ]. "La explosión roja sea más rara"	self extent: (Fondo alto / 64) @ (Fondo ancho / 64)! !!Explosion methodsFor: 'stepping and presenter' stamp: 'Anonymous 11/18/2023 00:18' prior: 33818123!step	eje:= self center.	(momento = 'expansion') ifTrue: [ "Se expande"		self extent: (self extent + ((Fondo ancho / 256) @ (Fondo alto / 256))).		].	(momento = 'compresion') ifTrue: [ "Se contrae"		self extent: (self extent - ((Fondo ancho / 256) @ (Fondo alto / 256))).		].	(self extent >= ((Fondo ancho / 16) @ (Fondo alto / 16))) ifTrue: [ "Cuando llega a un tamaño, pasa a contraerse"		momento:= 'compresion'.		].	(self extent < ((Fondo alto / 64) @ (Fondo ancho / 64))) ifTrue: [ "Cuando baja de un tamaño, se elimina"		self delete.		].	self center: (eje) 