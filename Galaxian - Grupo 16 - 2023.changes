ion + ((self width*0.41)@(self height * 0.9)).! !----SNAPSHOT----2023-11-20T19:15:58.907-03:00 18-11 ver2.image priorSource: 978913!Fondo removeSelector: #astronauta!!Fondo methodsFor: 'stepping and presenter' stamp: 'Anonymous 11/20/2023 19:16' prior: 34527956!start	|prota score|	(self world) allMorphsDo: [ :i | (i class = Menu) ifTrue: [ i delete ] ].	prota:= Protagonista new. "Nave principal"	prota center: self center.	prota color: (prota color alpha: 0).	self addMorph: prota.	score:= Score new. "puntaje"	score position: (self position).	self addMorph: score.	Estrella canAccelerate: true.	enjambremuerto:= true.! !----SNAPSHOT----2023-11-20T19:16:23.244-03:00 18-11 ver2.image priorSource: 979457!Morph subclass: #Protagonista	instanceVariableNames: 'invulnerable dash colorbase lockmov candash posicionando fuego inicio'	classVariableNames: 'bandBullet posx'	package: 'Jueguito'!!Protagonista methodsFor: 'initialization' stamp: 'Anonymous 11/20/2023 19:30' prior: 34533527!mouseEnter: anEventanEvent hand newKeyboardFocus: self.self extent: (Fondo ancho/20) @ (Fondo alto/25).self position: ((self owner) bottomCenter).self color: (self color alpha: 1).fuego extent: ((self extent)/6.1).	fuego color: (fuego color alpha: 1).	fuego center: self center.	fuego position: self position + ((self width*0.41)@(self height * 0.9)).	inicio:= false.! !!Protagonista methodsFor: 'initialization' stamp: 'Anonymous 11/20/2023 19:30' prior: 34534851!mouseEnter: anEventinicio ifTrue: [anEvent hand newKeyboardFocus: self.self extent: (Fondo ancho/20) @ (Fondo alto/25).self position: ((self owner) bottomCenter).self color: (self color alpha: 1).fuego extent: ((self extent)/6.1).	fuego color: (fuego color alpha: 1).	fuego center: self center.	fuego position: self position + ((self width*0.41)@(self height * 0.9)).	inicio:= false.	]! !----SNAPSHOT----2023-11-20T19:30:35.336-03:00 18-11 ver2.image priorSource: 980049!----SNAPSHOT----2023-11-20T