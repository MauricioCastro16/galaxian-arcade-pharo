ea uno nuevo"		enjambremuerto:= false.		enjambre:= Enjambre new.		enjambre color: (Color black alpha: 0). 		enjambre position: (ancho/2)@((enjambre bottom /4)).		self addMorph: enjambre.		( Estrella velocidad > 4) ifTrue: [ Estrella velocidad: (Estrella velocidad - 3) ].		( Nave velocidad > 26) ifTrue: [ Nave velocidad: (Nave velocidad - 5)]. "Aumenta la dificultad en cada enjambre"	].	! !----QUIT----2023-11-19T01:03:01.623-03:00 18-11.image priorSource: 633690!!Fondo methodsFor: 'initialization' stamp: 'Anonymous 11/19/2023 12:12' prior: 34188292!initialize	|prota score planeta|	super initialize. "superinicializamos la forma"	self startStepping. "inicializamos los pasos"	enjambremuerto:= true.	ancho:= Display height.	alto:= Display height. "Le asignamos el tamaño de la ejecución del programa para que este no varíe durante la ejecución"	self extent: (ancho)@(alto). "Tamaño del fondo"	self color: Color black.	self crearEstrellas. "Importa el orden para que las estrellas estén de fondo"	planeta:= Planeta new.	self addMorph: planeta.	prota:= Protagonista new. "Nave principal"	prota position: (ancho/2)@(alto-(prota bottom * 2)). "Centrarla en su posición"	self addMorph: prota.	score:= Score new. "puntaje"	self addMorph: score.! !EllipseMorph subclass: #Planeta	instanceVariableNames: 'ancho alto'	classVariableNames: ''	package: 'Jueguito'!!Planeta methodsFor: 'initialization' stamp: 'Anonymous 11/19/2023 12:15' prior: 34168468!initialize	|y z randomplanet|	super initialize.	randomplanet:= (1 to: 1) atRandom.	(randomplanet = 1) ifTrue: [		alto:= (Fondo alto / 5).		ancho:= (Fondo alto / 5) / 0.6.		self extent: ((Fondo alto / 5) @ alto).		self color: Color lightOrange darker darker darker darker darker darker darker darker darker darker darker.		self borderColor: self color darker.		y:= EllipseMorph new.		y extent: ((self width/0.6) @ (self height / 3)).		y center: self center.		self addMorph: y.		y color: Color orange dark