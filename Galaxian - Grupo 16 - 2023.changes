].		(((self position x - (self owner) left))abs < (Fondo ancho / 20)) ifTrue: [ direccion:= 'der' ]. "compara posición del enjambre con la parte izquierda del fondo, y da un margen de error"	(((self position x - ((self owner) right - self width)))abs < (Fondo ancho / 20)) ifTrue: [ direccion:= 'izq' ]. "idem pero con la parte derecha del fondo"		(direccion = 'der') ifTrue: [ self position: (self position + (((self position x - ((self owner) right-self width))abs / (Fondo ancho / 40)) @ 0)) ]. "Mientras más cerca esté del borde, se mueva más lento"	(direccion = 'izq') ifTrue: [ self position: (self position - (((self position x - ((self owner) left))abs / (Fondo ancho / 40)) @ 0)) ]. "Idem pero para la izquierda"		(self submorphs = { }) ifTrue: [self delete. Fondo enjambremuerto: true. Instrucciones vidas: (Instrucciones vidas + 1)]. "Si no quedan naves, se da como enjambre muerto, se borra y avisa a Fondo. Además da una vida"		((1 to: 1+(((self submorphs) size)/2) abs) atRandom = 1) ifTrue: [ "Hace un random para entrar en la función de enojar naves enemigas"		self submorphsDo: [ :i | ((1 to: (1 + (self submorphs) size) ) atRandom = 1) ifTrue: [ "Random para c/u de las naves"				(i class = Nave) ifTrue: [ "Se aclara que sea una Nave porque puede haber checkpoints en el enjambre"				(i enojado or: (i reposicion)) ifFalse: [ "Para que no se enoje una nave que ya está enojado ni tampoco una nave que se está reposicionando"				i enojado: true.  "enoja"				aux:= Checkpoint new. "Este checkpoint crea un objeto invisible para que, cuando la nave baje por la pantalla, pueda volver a su lugar de origen"				aux position: i position.				aux extent: i extent. "Idem forma y posición de la nave saliente"				self addMorph: aux. "Lo añado al enjambre"				i check: aux. "Hace una agregación entre la nave y el checkpoint"				] ] ] ].		 ].	((1 to: 1+(((self submorphs) size)/8) abs) atRandom = 1) ifTrue: [ "Random para entrar al proceso de lanzar una bala"		self submorphsDo: [ :i | ((1 to: (1 + (((self submorphs) size)) abs )) atRandom = 1) ifTrue: [ "Random para que una nave tire una bala"				(i class = Nave) ifTrue: [ "Nuevamente se hace la comparación para que no sea un checkpoint"				((1 to: 5) atRandom = 1) ifTrue: [ bullet:= BalaEnemiga new. bullet position: i position. (self owner) addMorph: bullet ]. "Nuevo random para bajar la probabilidad de bala, se agrega la bala al fondo"				] ] ] ].	! !----SNAPSHOT----2023-11-21T00:55:09.249-03:00 18-11 ver2.image priorSource: 996544!!Enjambre methodsFor: 'initialization' stamp: 'Anonymous 11/21/2023 00:55' prior: 34543202!initialize	|dir pArch line aux contx conty|	super initialize.	self startStepping.	self extent: (((Fondo ancho / 16)*10) @ ((Fondo alto / 24)*6)). "Setear tamaño para cualquier display"	direccion:= 'der'. "Arranca yendo para la derecha"	posicionando:= true.	"Abrir el documento de la configuración de las naves"	dir:= FileSystem disk workingDirectory.	pArch:= (dir,'\Naves.csv') readStream.	"config aleatoria"	((0 to: ((Instrucciones cantconfig)-1)) atRandom) timesRepeat: [ "Saltea las primeras n-1 configuraciones"		(7) timesRepeat: [ line:= pArch nextLine. ] 		].		conty:= -1.	(6) timesRepeat: [					line:= pArch nextLine.					conty:= conty + 1.					contx:= -1.					line do: [ :i| 						contx:= contx + 1.						aux:= Nave new.						aux position: (((Fondo alto / 16)*contx) @ ((Fondo alto / 24)*conty)). "Recorrer como una matriz"						self addMorph: aux.						(i = $■) ifTrue: [aux delete]. "Es aire, lo borra"						(i = $⌂) ifTrue: [aux color: Color orange].						(i = $○) ifTrue: [aux color: Color red].						(i = $▲) ifTrue: [aux color: Color pink].						(i = $☼) ifTrue: [aux color: Color green]. "Patron de las naves, según el color, indica las diferentes naves"								].					].				pArch close.! !----SNAPSHOT----2023-11-21T00:55:48.392-03:00 18-11 ver2.image priorSource: 999944!!Enjambre methodsFor: 'stepping and presenter' s