e.	banda:= Morph new.	banda extent: ((Display width - Display height)/2) @ alto.	banda left: self right.	! !----SNAPSHOT----2023-11-19T17:10:26.426-03:00 18-11 ver2.image priorSource: 827623!!Fondo methodsFor: 'initialization' stamp: 'Anonymous 11/19/2023 17:10' prior: 34382658!initialize	|prota score planeta banda|	super initialize. "superinicializamos la forma"	self startStepping. "inicializamos los pasos"	enjambremuerto:= true.	ancho:= Display height.	alto:= Display height. "Le asignamos el tamaño de la ejecución del programa para que este no varíe durante la ejecución"	self extent: (ancho)@(alto). "Tamaño del fondo"	self color: Color black.	self crearEstrellas. "Importa el orden para que las estrellas estén de fondo"	planeta:= Planeta new.	self addMorph: planeta.	prota:= Protagonista new. "Nave principal"	prota position: (ancho/2)@(alto-(prota bottom * 2)). "Centrarla en su posición"	self addMorph: prota.	score:= Score new. "puntaje"	self addMorph: score.	banda:= Morph new.	banda extent: ((Display width - Display height)/2) @ alto.	banda left: self right.	self addMorph: banda.	! !!Fondo methodsFor: 'initialization' stamp: 'Anonymous 11/19/2023 17:14' prior: 34383660!initialize	|prota score planeta banda|	super initialize. "superinicializamos la forma"	self startStepping. "inicializamos los pasos"	enjambremuerto:= true.	ancho:= Display height.	alto:= Display height. "Le asignamos el tamaño de la ejecución del programa para que este no varíe durante la ejecución"	self extent: (ancho)@(alto). "Tamaño del fondo"	self color: Color black.	self crearEstrellas. "Importa el orden para que las estrellas estén de fondo"	planeta:= Planeta new.	self addMorph: planeta.	prota:= Protagonista new. "Nave principal"	prota position: (ancho/2)@(alto-(prota bottom * 2)). "Centrarla en su posición"	self addMorph: prota.	score:= Score new. "puntaje"	self addMorph: score.	banda:= Morph new.	banda extent: ((Display width - Display height)/