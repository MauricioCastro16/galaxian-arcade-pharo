uerto start'	package: 'Jueguito'!!Fondo methodsFor: 'initialization' stamp: 'Anonymous 11/21/2023 01:21' prior: 34580944!step	|enjambre texto|	(enjambremuerto) ifTrue: [ "Cuando muere un enjambre (todas sus naves) crea uno nuevo"		enjambremuerto:= false.		enjambre:= Enjambre new.		enjambre color: (Color black alpha: 0). 		enjambre center: (self topCenter - (enjambre height)).		self addMorph: enjambre behind: bordes.		( Estrella velocidad > 4) ifTrue: [ Estrella velocidad: (Estrella velocidad - 3) ].		( Nave velocidad > 26) ifTrue: [ Nave velocidad: (Nave velocidad - 5)]. "Aumenta la dificultad en cada enjambre"		texto:= TextMorph new.		texto contents: ('¡Se viene el ', nroenjambre asString, '° enjambre!!').		texto color: (Color white).		enjambre mensaje: texto.		texto center: self center.		self addMorph: texto behind: prota.	].	! !!Fondo methodsFor: 'initialization' stamp: 'Anonymous 11/21/2023 01:22' prior: 34588218!step	|enjambre texto|	(enjambremuerto) ifTrue: [ "Cuando muere un enjambre (todas sus naves) crea uno nuevo"		enjambremuerto:= false.		enjambre:= Enjambre new.		enjambre color: (Color black alpha: 0). 		enjambre center: (self topCenter - (enjambre height)).		self addMorph: enjambre behind: bordes.		( Estrella velocidad > 4) ifTrue: [ Estrella velocidad: (Estrella velocidad - 3) ].		( Nave velocidad > 26) ifTrue: [ Nave velocidad: (Nave velocidad - 5)]. "Aumenta la dificultad en cada enjambre"		nroenjambre := nroenjambre + 1.		texto:= TextMorph new.		texto contents: ('¡Se viene el ', nroenjambre asString, '° enjambre!!').		texto color: (Color white).		enjambre mensaje: texto.		texto center: self center.		self addMorph: texto behind: prota.	].	! !!Fondo methodsFor: 'initialization' stamp: 'Anonymous 11/21/2023 01:22' prior: 34542477!initialize	|planeta|	super initialize. "superinicializamos la forma"	self startStepping. "inicializamos los pasos"	enjambremuerto:= false.	nroenjambre := 1.	ancho:= Display height.	alto:= Display height. "Le asignamos el tamaño de la ejecución del programa para que este no varíe durante la ejecución"	self extent: (ancho)@(alto). "Tamaño del fondo"	self color: Color black.	self crearEstrellas. "Importa el orden para que las estrellas estén de fondo"	planeta:= Planeta new.	planeta center: self center.	self addMorph: planeta.	self bordes.	! !Morph subclass: #Enjambre	instanceVariableNames: 'direccion posicionando mensaje'	classVariableNames: ''	package: 'Jueguito'!!Enjambre methodsFor: 'initialization' stamp: 'Anonymous 11/21/2023 01:22' prior: 34564491!initialize	|dir pArch line aux contx conty|	super initialize.	self startStepping.	self extent: (((Fondo ancho / 16)*10) @ ((Fondo alto / 24)*6)). "Setear tamaño para cualquier display"	direccion:= 'der'. "Arranca yendo para la derecha"	posicionando:= true.		"Abrir el documento de la configuración de las naves"	dir:= FileSystem disk workingDirectory.	pArch:= (dir,'\Naves.csv') readStream.	"config aleatoria"	((0 to: ((Instrucciones cantconfig)-1)) atRandom) timesRepeat: [ "Saltea las primeras n-1 configuraciones"		(7) timesRepeat: [ line:= pArch nextLine. ] 		].		conty:= -1.	(6) timesRepeat: [					line:= pArch nextLine.					conty:= conty + 1.					contx:= -1.					line do: [ :i| 						contx:= contx + 1.						aux:= Nave new.						aux position: (((Fondo alto / 16)*contx) @ ((Fondo alto / 24)*conty)). "Recorrer como una matriz"						self addMorph: aux.						(i = $■) ifTrue: [aux delete]. "Es aire, lo borra"						(i = $⌂) ifTrue: [aux color: Color orange].						(i = $○) ifTrue: [aux color: Color red].						(i = $▲) ifTrue: [aux color: Color pink].						(i = $☼) ifTrue: [aux color: Color green]. "Patron de las naves, según el color, indica las diferentes naves"								].					].				pArch close.! !Enjambre removeSelector: #nroenjambre!!Enjambre methodsFor: 'stepping and presenter' stamp: 'Anonymous 11/21/2023 01:22' prior: 34584939!step	|aux bullet co