ontalBar color: Color white.verticalBar := self bounds insetBy: (self width / 3) @ 10.aCanvas fillRectangle: verticalBar color: self color.Transcript show: (self width); cr; show: (self height).! !----SNAPSHOT----2023-11-17T23:58:42.837-03:00 17-11 ver2.image priorSource: 512076!!Nave methodsFor: 'drawing' stamp: 'Anonymous 11/17/2023 23:59' prior: 34072627!drawOn: aCanvas "Dibuja la nave"| horizontalBar verticalBar|horizontalBar := self bounds insetBy: (self width/ 34) @ (self height / 3).aCanvas fillRectangle: horizontalBar color: self color.horizontalBar := self bounds insetBy: 8 @ (self height / 2.3).aCanvas fillRectangle: horizontalBar color: Color white.verticalBar := self bounds insetBy: (self width / 3) @ 10.aCanvas fillRectangle: verticalBar color: self color.Transcript show: (self width); cr; show: (self height).! !!Nave methodsFor: 'drawing' stamp: 'Anonymous 11/17/2023 23:59' prior: 34073267!drawOn: aCanvas "Dibuja la nave"| horizontalBar verticalBar|horizontalBar := self bounds insetBy: (self width/ 34) @ (self height / 3).aCanvas fillRectangle: horizontalBar color: self color.horizontalBar := self bounds insetBy: (self width / 7) @ (self height / 2.3).aCanvas fillRectangle: horizontalBar color: Color white.verticalBar := self bounds insetBy: (self width / 3) @ 10.aCanvas fillRectangle: verticalBar color: self color.Transcript show: (self width); cr; show: (self height).! !!Nave methodsFor: 'drawing' stamp: 'Anonymous 11/17/2023 23:59' prior: 34073835!drawOn: aCanvas "Dibuja la nave"| horizontalBar verticalBar|horizontalBar := self bounds insetBy: (self width/ 34) @ (self height / 3).aCanvas fillRectangle: horizontalBar color: self color.horizontalBar := self bounds insetBy: (self width / 7) @ (self height / 2.3).aCanvas fillRectangle: horizontalBar color: Color white.verticalBar := self bounds insetBy: (self width / 3) @ (self height / 4.2).aCanvas fillRectangle: verticalBar color: self color.! !----SNAPSHOT----2023-11-17T23:59:55.293-03:00 17-11 ver2.image priorSource: 518668!!Nave methodsFor: 'stepping and presenter' stamp: 'Anonymous 11/18/2023 00:04' prior: 33999896!step	|correctx correcty|	(((1 to: 50) atRandom = 1) and: (velocidad > 20)) ifTrue: [ velocidad:= velocidad - 1]. "Mientras más pase el tiempo, más rápido van las naves"	 (enojado) ifTrue: [  "Función enojado"		self position: self position + (0 @ 5).		((1 to: 3) atRandom = 1) ifTrue: [ "Probabilidad de acercarse a la nave prota"		correctx:= (Protagonista posx - self position x) / (Fondo ancho / 50). "Corrector de posición en relación con la posición del prota" 		self position: self position + (correctx @ 0).		]].	(self position y > Fondo alto) ifTrue: [ self position: ((check position x) @ 0). enojado:= false. reposicion:= true]. "Cuando pasa la pantalla, deja de estar enojado y entra en modo reposición"	(reposicion) ifTrue: [ "Función reposición"		correctx:= ((check position x - self position x) / (Fondo ancho/30)  ).		correcty:= ((check position y - self position y) / (Fondo ancho/30) ). "Corrector de x e y"		self position: self position + (correctx @ correcty). "Corrige su posición lentamente hasta llegar al checkpoint"		((self position y) truncated) = ((check position y) truncated) ifTrue: [reposicion:= false. check delete] "Compara posiciones con el checkpoint truncando para que termine"		].! !----SNAPSHOT----2023-11-18T00:05:11.55-03:00 17-11 ver2.image priorSource: 520448!----SNAPSHOT----2023-11-18T00:06:09.619-03:00 17-11 ver2.image priorSource: 521873!!Nave methodsFor: 'stepping and presenter' stamp: 'Anonymous 11/18/2023 00:06' prior: 33999896!step	|correctx correcty|	(((1 to: 50) atRandom = 1) and: (velocidad > 20)) ifTrue: [ velocidad:= velocidad - 1]. "Mientras más pasa el tiempo, acelera la velocidad"	 (enojado) ifTrue: [  "Función enojado"		self position: self position + (0 @ 5).		((1 to: 3) atRandom = 1) ifTrue: [ 		correctx:= (Protagonista posx - self position x) / (Fondo ancho / 50). "Ajusta su posición respecto al protagonista"		self position: self position + (correctx @ 0).		]].	(self position y > Fondo alto) ifTrue: [ self position: ((check position x) @ 0). enojado:= false. reposicion:= true]. "Si sale por debajo de la pantalla, entra en modo reposición, deja de estar enojado y utiliza el checkpoint"	(reposicion) ifTrue: [		correctx:= ((check position x - self position x) / (Fondo ancho/30)  ).		correcty:= ((check position y - self position y) / (Fondo ancho/30) ).		self position: self position + (correctx @ correcty). "Corrige su posición respecto al checkpoint"		((self position y) truncated) = ((check position y) truncated) ifTrue: [reposicion:= false. check delete] "Verifica que llegó a su posición"		].! !----SNAPSHOT----2023-11-18T00:06:41.654-03:00 17-11 ver2.image priorSource: 521957!!BalaEnemiga methodsFor: 'stepping and presenter' stamp: 'Anonymous 11/18/2023 00:07' prior: 33879513!step	self position: (self position + (0 @ 10)). 	(((self position) y) < ((self owner) top - self height)) ifTrue: [ self delete]. "Si llega al final, se elimina"			! !!BalaEnemiga methodsFor: 'stepping and presenter' stamp: 'Anonymous 11/18/2023 00:07' prior: 34077880!step	self position: (self position + (0 @ (Fondo alto / 100))). 	(((self position) y) < ((self owner) top - self height)) ifTrue: [ self delete]. "Si llega al final, se elimina"			! !----SNAPSHOT----2023-11-18T00:07:55.434-03:00 17-11 ver2.image priorSource: 523259!----SNAPSHOT----2023-11-18T00:07:57.927-03:00 17-11 ver2.image priorSource: 523912!!BalaEnemiga methodsFor: 'stepping and presenter' stamp: 'Anonymous 11/18/2023 00:08' prior: 34078156!step	self position: (self position + (0 @ (Fondo alto / 100))). "Movimiento relativo al display"	(((self position) y) < ((self owner) top - self height)) ifTrue: [ self delete]. "Si llega al final, se elimina"			! !!Checkpoint methodsFor: 'initialization' stamp: 'Anonymous 11/18/2023 00:08' prior: 33798781!initialize	super initialize.	self color: (Color yellow alpha: 0) "Lo hace invisible"! !!Checkpoint methodsFor: 'initialization' stamp: 'Anonymous 11/18/2023 00:09' prior: 33798945!drawOn: aCanvas "Para que tenga la misma forma de la nave, por las dudas"| horizontalBar verticalBar|horizontalBar := self bounds insetBy: 1.5 @ (self height / 3).aCanvas fillRectangle: horizontalBar color: self color.horizontalBar := self bounds insetBy: 8 @ (self height / 2.3).aCanvas fillRectangle: horizontalBar color: (Color white alpha: 0).verticalBar := self bounds insetBy: (self width / 3) @ 10.aCanvas fillRectangle: verticalBar color: self color.! !!Bala methodsFor: 'initialization' stamp: 'Anonymous 11/18/2023 00:09' prior: 33822882!step	|explosion|	self position: (self position - (0 @ (Fondo alto / 100))).	(self owner) submorphsDo: [ :i | 		(i class = Enjambre) ifTrue: [ 			i submorphsDo: [:j | 				(j class = Nave) ifTrue: [				(self intersects: j bounds) ifTrue: [ 					(j color = Color blue) ifTrue: [ 						Instrucciones score: (Instrucciones score + 10)						 ].					(j color = Color red) ifTrue: [ 						Instrucciones score: (Instrucciones score + 20)						 ].					(j color = Color pink) ifTrue: [ 						Instrucciones score: (Instrucciones score + 50)						 ].					(j color = Color green) ifTrue: [ 						Instrucciones score: (Instrucciones score + 100)						 ].					explosion:= Explosion new.					(j owner) addMorph: explosion.					explosion center: j center.					Protagonista bandBullet: true.					j delete.   					self delete.					((j check) isNil) ifFalse: [ j check delete ]					] ] 				] 			] 		].	(((self position) y) < (0)) ifTrue: [ self delete. Protagonista bandBullet: true ].		! !----SNAPSHOT----2023-11-18T00:09:27.828-03:00 17-11 ver2.image priorSource: 523997!----SNAPSHOT----2023-11-18T00:10:09.925-03:00 17-11 ver2.image priorSource: 526244!!Bala methodsFor: 'initialization' stamp: 'Anonymous 11/18/2023 00:12' prior: 34079674!step	|explosion|	self position: (self position - (0 @ (Fondo alto / 100))).	(self owner) submorphsDo: [ :i | "Pregunta por todos los submorphs del fondo"		(i class = Enjambre) ifTrue: [  "Detecta al enjambre"			i submorphsDo: [:j | 				(j class = Nave) ifTrue: [ "busca las naves"				(self intersects: j bounds) ifTrue: [ "Detecta si la bala está en contacto con una nave"					(j color = Color blue) ifTrue: [ 						Instrucciones score: (Instrucciones score + 10)						 ].					(j color = Color red) ifTrue: [ 						Instrucciones score: (Instrucciones score + 20)						 ].					(j color = Color pink) ifTrue: [ 						Instrucciones score: (Instrucciones score + 50)						 ].					(j color = Color green) ifTrue: [ 						Instrucciones score: (Instrucciones score + 100) "Según el color de la nave, suma distinto puntaje"						 ].					explosion:= Explosion new. "Crea una explosión"					(j owner) addMorph: explosion. "Le asigna al fondo"					explosion center: j center. 					Protagonista bandBullet: true. "Permite que el protagonista vuelva a disparar"					j delete.   "Mata a la nave"					self delete. "Se elimina"					(j check) ifNotNil: [ j check delete ] "Si existe un checkpoint (es decir, la nave atacó y no se repuso), también tiene que borrarlo"					] ] 				] 			] 		].	(((self position) y) < (0)) ifTrue: [ self delete. Protagonista bandBullet: true ].		! !!Bala methodsFor: 'initialization' stamp: 'Anonymous 11/18/2023 00:12' prior: 34080935!step	|explosion|	self position: (self position - (0 @ (Fondo alto / 100))).	(self owner) submorphsDo: [ :i | "Pregunta por todos los submorphs del fondo"		(i class = Enjambre) ifTrue: [  "Detecta al enjambre"			i submorphsDo: [:j | 				(j class = Nave) ifTrue: [ "busca las naves"				(self intersects: j bounds) ifTrue: [ "Detecta si la bala está en contacto con una nave"					(j color = Color blue) ifTrue: [ 						Instrucciones score: (Instrucciones score + 10)						 ].					(j color =