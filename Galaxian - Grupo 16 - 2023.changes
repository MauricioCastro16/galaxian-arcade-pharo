"Abrir el documento de la configuración de las naves"	dir:= FileSystem disk workingDirectory.	pArch:= (dir,'\Naves.csv') readStream.	"config aleatoria"	((0 to: ((Instrucciones cantconfig)-1)) atRandom) timesRepeat: [ "Saltea las primeras n-1 configuraciones"		(7) timesRepeat: [ line:= pArch nextLine. ] 		].		conty:= -1.	(6) timesRepeat: [					line:= pArch nextLine.					conty:= conty + 1.					contx:= -1.					line do: [ :i| 						contx:= contx + 1.						aux:= Nave new.						aux position: (((Fondo alto / 16)*contx) @ ((Fondo alto / 24)*conty)). "Recorrer como una matriz"						self addMorph: aux.						(i = $■) ifTrue: [aux delete]. "Es aire, lo borra"						(i = $⌂) ifTrue: [aux color: Color purple].						(i = $○) ifTrue: [aux color: Color red].						(i = $▲) ifTrue: [aux color: Color pink].						(i = $☼) ifTrue: [aux color: Color green]. "Patron de las naves, según el color, indica las diferentes naves"								].					].				pArch close.! !!Enjambre methodsFor: 'initialization' stamp: 'Anonymous 11/20/2023 19:36' prior: 34537597!initialize	|dir pArch line aux contx conty|	super initialize.	self startStepping.	self extent: (((Fondo ancho / 16)*10) @ ((Fondo alto / 24)*6)). "Setear tamaño para cualquier display"	direccion:= 'der'. "Arranca yendo para la derecha"		"Abrir el documento de la configuración de las naves"	dir:= FileSystem disk workingDirectory.	pArch:= (dir,'\Naves.csv') readStream.	"config aleatoria"	((0 to: ((Instrucciones cantconfig)-1)) atRandom) timesRepeat: [ "Saltea las primeras n-1 configuraciones"		(7) timesRepeat: [ line:= pArch nextLine. ] 		].		conty:= -1.	(6) timesRepeat: [					line:= pArch nextLine.					conty:= conty + 1.					contx:= -1.					line do: [ :i| 						contx:= contx + 1.						aux:= Nave new.						aux position: (((Fondo alto / 16)*contx) @ ((Fondo alto / 24)*conty)). "Recorrer como una matriz"						self addMorph: aux.						(i = $■) ifTrue: [aux delete]. "Es aire, lo borra"						(i = $⌂) ifTrue: [aux color: Color purple lighter lighter].						(i = $○) ifTrue: [aux color: Color red].						(i = $▲) ifTrue: [aux color: Color pink].						(i = $☼) ifTrue: [aux color: Color green]. "Patron de las naves, según el color, indica las diferentes naves"								].					].				pArch close.! !----SNAPSHOT----2023-11-20T19:36:32.522-03:00 18-11 ver2.image priorSource: 982987!!Enjambre methodsFor: 'initialization' stamp: 'Anonymous 11/20/2023 19:37' prior: 34538921!initialize	|dir pArch line aux contx conty|	super initialize.	self startStepping.	self extent: (((Fondo ancho / 16)*10) @ ((Fondo alto / 24)*6)). "Setear tamaño para cualquier display"	direccion:= 'der'. "Arranca yendo para la derecha"		"Abrir el documento de la configuración de las naves"	dir:= FileSystem disk workingDirectory.	pArch:= (dir,'\Naves.csv') readStream.	"config aleatoria"	((0 to: ((Instrucciones cantconfig)-1)) atRandom) timesRepeat: [ "Saltea las primeras n-1 configuraciones"		(7) timesRepeat: [ line:= pArch nextLine. ] 		].		conty:= -1.	(6) timesRepeat: [					line:= pArch nextLine.					conty:= conty + 1.					contx:= -1.					line do: [ :i| 						contx:= contx + 1.						aux:= Nave new.						aux position: (((Fondo alto / 16)*contx) @ ((Fondo alto / 24)*conty)). "Recorrer como una matriz"						self addMorph: aux.						(i = $■) ifTrue: [aux delete]. "Es aire, lo borra"						(i = $⌂) ifTrue: [aux color: Color lightBlue].						(i = $○) ifTrue: [aux color: Color red].						(i = $▲) ifTrue: [aux color: Color pink].						(i = $☼) ifTrue: [aux color: Color green]. "Patron de las naves, según el color, indica las diferentes naves"								].					].				pArch close.! !----SNAPSHOT----2023-11-20T19:37:18.684-03:00 18-11 ver2.image priorSource: 985736!!Fondo methodsFor: 'initialization' stamp: 'Anonymous 11/20/2023 19:37' prior: 34512356!initialize	|planeta|	super initialize. "superinicializamos la forma"	self startStepping. "inicializamos los pasos"	enjambremuerto:= false.	ancho:= Display height.	alto:= Display height. "Le asignamos el tamaño de la ejecución del programa para que este no varíe durante la ejecución"	self extent: (ancho)@(alto). "Tamaño del fondo"	self color: Color black.	self crearEstrellas. "Importa el orden para que las estrellas estén de fondo"	planeta:= Planeta new.	planeta center: self center.	self addMorph: planeta.	self bordes.	! !----SNAPSHOT----2023-11-20T19:37:29.602-03:00 18-11 ver2.image priorSource: 987148!!Fondo methodsFor: 'initialization' stamp: 'Anonymous 11/20/2023 19:37' prior: 34541755!initialize	|planeta|	super initialize. "superinicializamos la forma"	self startStepping. "inicializamos los pasos"	enjambremuerto:= false.	ancho:= Display height.	alto:= Display height. "Le asignamos el tamaño de la ejecución del programa para que este no varíe durante la ejecución"	self extent: (ancho)@(alto). "Tamaño del fondo"	self color: Color black.	self crearEstrellas. "Importa el orden para que las estrellas estén de fondo"	planeta:= Planeta new.	planeta center: self center.	self addMorph: planeta.	self bordes.	! !----SNAPSHOT----2023-11-20T19:37:39.408-03:00 18-11 ver2.image priorSource: 987870!!Enjambre methodsFor: 'initialization' stamp: 'Anonymous 11/20/2023 19:38' prior: 34540346!initialize	|dir pArch line aux contx conty|	super initialize.	self startStepping.	self extent: (((Fondo ancho / 16)*10) @ ((Fondo alto / 24)*6)). "Setear tamaño para cualquier display"	direccion:= 'der'. "Arranca yendo para la derecha"		"Abrir el documento de la configuración de las naves"	dir:= FileSystem disk workingDirectory.	pArch:= (dir,'\Naves.csv') readStream.	"config aleatoria"	((0 to: ((Instrucciones cantconfig)-1)) atRandom) timesRepeat: [ "Saltea las primeras n-1 configuraciones"		(7) timesRepeat: [ line:= pArch nextLine. ] 		].		conty:= -1.	(6) timesRepeat: [					line:= pArch nextLine.					conty:= conty + 1.					contx:= -1.					line do: [ :i| 						contx:= contx + 1.						aux:= Nave new.						aux position: (((Fondo alto / 16)*contx) @ ((Fondo alto / 24)*conty)). "Recorrer como una matriz"						self addMorph: aux.						(i = $■) ifTrue: [aux delete]. "Es aire, lo borra"						(i = $⌂) ifTrue: [aux color: Color orange].						(i = $○) ifTrue: [aux color: Color red].						(i = $▲) ifTrue: [aux color: Color pink].						(i = $☼) ifTrue: [aux color: Color green]. "Patron de las naves, según el color, indica las diferentes naves"								].					].				pArch close.! !----SNAPSHOT----2023-11-20T19:38:09.633-03:00 18-11 ver2.image priorSource: 988592!----SNAPSHOT----2023-11-20T19:38:47.436-03:00 18-11 ver2.image priorSource: 990001!!Estrella methodsFor: 'stepping and presenter' stamp: 'Anonymous 11/20/2023 19:38' prior: 34494918!step	|randdir|	(velocidad > 30.1 and: canAccelerate) ifTrue: [ velocidad:= velocidad - 0.01 ].	(direccion = 'abajo') ifTrue: [ self position: (self position + (0 @ (Fondo alto / 100))).]. "Según la dirección, se mueven para un lado establecido"	(direccion = 'izquierda') ifTrue: [ self position: (self position - ((Fondo ancho / 100) @ 0)).].	(direccion = 'diagonal') ifTrue: [ self position: (self position + (0 @ (Fondo alto / 100))). self position: (self position - ((Fondo ancho / 100) @ 0)).].	(((self position) y) > ((self owner) bottom - self height)) ifTrue: [ self position: (self position x) @ (self owner) top]. 	(((self position) x) < ((self owner) left - self width)) ifTrue: [ self position: ((self owner) right-self width) @ (self position y)]. "Si se sale de la pantalla, vuelve a una posición relativa tanto en x como en y"	(self color diff: Color black)<0.1 "Hace que parpadee la estrella"	ifTrue:[self color: Color white] 	ifFalse:[self color:self color darker].	(((1 to: 800) atRandom = 1) and: (velocidad > 1 and: canAccelerate)) ifTrue: [ velocidad:= velocidad - 1 ]. "Las estrellas cada vez van más rápido"	((1 to: 10000) atRandom = 1) ifTrue: [ randdir:= (1 to: 3) atRandom. (randdir=1) ifTrue: [ direccion:= 'abajo' ]. (randdir=2) ifTrue: [ direccion:= 'diagonal' ]. (randdir=3) ifTrue: [ direccion:= 'izquierda' ]] "Cambia la dirección de las estrellas"! !----SNAPSHOT----2023-11-20T19:38:57.442-03:00 18-11 ver2.image priorSource: 990086!!Planeta methodsFor: 'initialization' stamp: 'Anonymous 11/20/2023 19:41' prior: 34381760!initialize	super initialize.	visible:= false.	alto:= (Fondo alto / 3).	ancho:= (Fondo alto / 3).	self extent: (ancho @ alto).	self color: (self color alpha: 1).	self borderColor: (self color alpha: 0)! !----SNAPSHOT----2023-11-20T19:41:03.389-03:00 18-11 ver2.image priorSource: 991672!!Planeta methodsFor: 'initialization' stamp: 'Anonymous 11/20/2023 19:41' prior: 34546281!initialize	super initialize.	visible:= false.	alto:= (Fondo alto / 3).	ancho:= (Fondo alto / 3).	self extent: (ancho @ alto).	self color: (self color alpha: 0).	self borderColor: (self color alpha: 0)! !----SNAPSHOT----2023-11-20T19:41:28.544-03:00 18-11 ver2.image priorSource: 992059!----QUIT----2023-11-20T19:41:32.439-03:00 18-11 ver2.image priorSource: 992446!!Fondo methodsFor: 'initialization' stamp: 'Anonymous 11/21/2023 00:47' prior: 34389669!step	|enjambre|	(enjambremuerto) ifTrue: [ "Cuando muere un enjambre (todas sus naves) crea uno nuevo"		enjambremuerto:= false.		enjambre:= Enjambre new.		enjambre color: (Color black alpha: 0). 		enjambre center: (self topCenter - (enjambre height / 2)).		self addMorph: enjambre behind: bordes.		( Estrella velocidad > 4) ifTrue: [ Estrella velocidad: (Estrella velocidad - 3) ].		( Nave velocidad > 26) ifTrue: [ Nave velocidad: (Nave velocidad - 5)]. "Aumenta la dificultad en cada enjambre"	].	! !----SNAPSHOT----2023-11-21T00:47:40.829-03:00 18-11 ver2.image priorSource: 992531!!Fondo methodsFor: 'initialization' stamp: 'Anonymous 11/21/2023 00:48' prior: 34547134!step	|enjambre|	(enjambremuerto) ifTrue: [ "Cuando muere un enjambre (todas sus naves) 