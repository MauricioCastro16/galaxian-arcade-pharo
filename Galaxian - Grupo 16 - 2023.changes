t: (100 @ 50);	 	actionSelector: #start;	 	actWhen: #buttonDown;    	center: self center.! !!Juego methodsFor: 'initialization' stamp: 'Anonymous 11/26/2023 00:04' prior: 34805827!initialize	vent:= OSWindowWorldMorph new.	fondo:= Fondo new.	fondo center: (Display width / 2) @ (Display height / 2).	fondo openInWorld: vent.	defaultVidas:= Instrucciones vidas.	(self class) abrirGameOver.	vent open.! !!GameOver methodsFor: 'initialization' stamp: 'Anonymous 11/26/2023 00:05' prior: 34810888!initialize	 super initialize.	 error:= false.    self extent:((Fondo ancho / 1.5)@(Fondo alto / 1.5)).    self color: (Color r:0.9  g:0.9  b:0.9 alpha: 0.7).    titulo:= TextMorph new.	 self addMorph: titulo.    titulo contents: 'GAME OVER';    	center: self center - (0@(Fondo alto / 6));    	color: Color black.    continue:= SimpleButtonMorph new.	 self addMorph: continue.     continue label: 'CONTINUAR';    	center: self center + (0@(Fondo alto / 6));	 	target: self;	 	actionSelector: #guardarScore;	 	actWhen: #buttonDown.	 self mostrarVentanaTexto.	 anuncio:= TextMorph new.	 self addMorph: anuncio.	 anuncio center: self center;    	color: Color black.! !!GameOver methodsFor: 'initialization' stamp: 'Anonymous 11/26/2023 00:05' prior: 34813002!initialize	 super initialize.	 error:= false.    self extent:((Fondo ancho / 1.5)@(Fondo alto / 1.5)).    self color: (Color r:0.9  g:0.9  b:0.9 alpha: 0.7).    titulo:= TextMorph new.	 self addMorph: titulo.    titulo contents: 'GAME OVER';    	center: self center - (0@(Fondo alto / 6));    	color: Color black.    continue:= SimpleButtonMorph new.	 self addMorph: continue.     continue label: 'CONTINUAR';    	center: self center + (0@(Fondo alto / 7));	 	target: self;	 	actionSelector: #guardarScore;	 	actWhen: #buttonDown.	 self mostrarVentanaTexto.	 anuncio:= TextMorph new.	 self addMorph: anuncio.	 anuncio center: self center;    	color: Color black.! !!GameOver methodsFor: 'initialization' stamp: 'Anonymous 11/26/2023 00:05' prior: 34813781!initialize	 super initialize.	 error:= false.    self extent:((Fondo ancho / 1.5)@(Fondo alto / 1.5)).    self color: (Color r:0.9  g:0.9  b:0.9 alpha: 0.7).    titulo:= TextMorph new.	 self addMorph: titulo.    titulo contents: 'GAME OVER';    	center: self center - (0@(Fondo alto / 6));    	color: Color black.    continue:= SimpleButtonMorph new.	 self addMorph: continue.     continue label: 'CONTINUAR';    	center: self center + (0@(Fondo alto / 4));	 	target: self;	 	actionSelector: #guardarScore;	 	actWhen: #buttonDown.	 self mostrarVentanaTexto.	 anuncio:= TextMorph new.	 self addMorph: anuncio.	 anuncio center: self center;    	color: Color black.! !!GameOver methodsFor: 'initialization' stamp: 'Anonymous 11/26/2023 00:05' prior: 34814560!initialize	 super initialize.	 error:= false.    self extent:((Fondo ancho / 1.5)@(Fondo alto / 1.5)).    self color: (Color r:0.9  g:0.9  b:0.9 alpha: 0.7).    titulo:= TextMorph new.	 self addMorph: titulo.    titulo contents: 'GAME OVER';    	center: self center - (0@(Fondo alto / 6));    	color: Color black.    continue:= SimpleButtonMorph new.	 self addMorph: continue.     continue label: 'CONTINUAR';    	center: self center + (0@(Fondo alto / 4));	 	target: self;	 	actionSelector: #guardarScore;	 	actWhen: #buttonDown.	 self mostrarVentanaTexto.	 anuncio:= TextMorph new.	 self addMorph: anuncio.	 anuncio center: self center;    	color: Color black.! !!Juego methodsFor: 'initialization' stamp: 'Anonymous 11/26/2023 00:05' prior: 34812681!initialize	vent:= OSWindowWorldMorph new.	fondo:= Fondo new.	fondo center: (Display width / 2) @ (Display height / 2).	fondo openInWorld: vent.	defaultVidas:= Instrucciones vidas.	(self class) abrirMenu.	vent open.! !!Bala methodsFor: 'initialization' stamp: 'Anonymous 11/26/2023 00:14' prior: 34670303!step	|explosion|	self position: (self position - (0 @ (Fondo alto / 100))).	(self owner) submorphsDo: [ :i | "Pregunta por todos los submorphs del fondo"		(i class = Enjambre) ifTrue: [  "Detecta al enjambre"			i submorphsDo: [:j | 				(j class = Nave) ifTrue: [ "busca las naves"				(self intersects: j bounds) ifTrue: [ "Detecta si la bala está en contacto con una nave"					(j color = Color orange) ifTrue: [ 						Instrucciones score: (Instrucciones score + 10)						 ].					(j color = Color red) ifTrue: [ 						Instrucciones score: (Instrucciones score + 20)						 ].					(j color = Color pink) ifTrue: [ 						Instrucciones score: (Instrucciones score + 50)						 ].					(j color = Color green) ifTrue: [ 						Instrucciones score: (Instrucciones score + 100) "Según el color de la nave, suma distinto puntaje"						 ].					explosion:= Explosion new. "Crea una explosión"					(j owner) addMorph: explosion. "Le asigna al fondo"					explosion center: j center. 					Protagonista bandBullet: true. "Permite que el protagonista vuelva a disparar"					j delete.   "Mata a la nave"					self delete. "Se elimina"					(j check) ifNotNil: [ j check delete ] "Si existe un checkpoint (es decir, la nave atacó y no se repuso), también tiene que borrarlo"					] ] 				] 			] 		].	(((self position) y) < (0)) ifTrue: [ self delete. Protagonista bandBullet: true ]. "Pregunto si salió por arriba de la pantalla, se elimina y el protagonista puede volver a disparar"		! !----SNAPSHOT----2023-11-26T00:33:30.887-03:00 23-11.image priorSource: 1256191!----QUIT----2023-11-26T00:33:33.055-03:00 23-11.image priorSource: 1263499!Object subclass: #Instrucciones	instanceVariableNames: ''	classVariableNames: 'cantconfig score vidas'	package: 'Jueguito'!----SNAPSHOT----2023-11-26T10:30:31.954-03:00 23-11.image priorSource: 1263580!----SNAPSHOT----2023-11-26T10:31:37.845-03:00 23-11.image priorSource: 1263785!!Planeta methodsFor: 'as yet unclassified' stamp: 'Anonymous 11/26/2023 10:31' prior: 34366730!construirPlaneta	|y z randomplanet fill color1 color2|	randomplanet:= (1 to: 3) atRandom. "Elige un planeta de n planetas"	(randomplanet = 1) ifTrue: [		alto:= (Fondo alto / 3).		ancho:= (Fondo alto / 3) / 0.6.		self extent: (ancho * 0.6 @ alto).		color1 := Color lightOrange darker darker darker darker darker darker darker darker darker darker.		color2 := color1 darker darker darker darker.		fill := GradientFillStyle ramp: {0.0 -> color1. 1.0 -> color2}.		fill origin: self topLeft.		fill direction: 0 @ self bounds extent y.		fill normal: self bounds extent x @ 0.		fill radial: false.		self fillStyle: fill.		self borderColor: (self color alpha: 0).		y:= EllipseMorph new. "Anillo"		y extent: (ancho @ (self height / 3)).		y center: self center.		color1 := Color orange darker darker darker darker darker darker darker darker darker darker darker.		color2 := color1 darker.		fill := GradientFillStyle ramp: {0.0 -> color1. 1.0 -> color2}.		fill origin: y topLeft.		fill direction: 0 @ y bounds extent y.		fill normal: y bounds extent x @ 0.		fill radial: false.		y fillStyle: fill.		y borderColor: (y color alpha: 0).		self addMorph: y.		z:= EllipseMorph new. "Superposición para que parezca un anillo"		z extent: ((self width / 1.052) @ (self height / 3)).		z center: self center - (0 @ (self height / 7.5)).		color1 :=  Color lightOrange darker darker darker darker darker darker darker darker darker darker.		color2 := color1 darker darker darker darker.		fill := GradientFillStyle ramp: {0.0 -> color1.  1.0-> color2}.		fill origin: self topLeft.		fill direction: 0 @ self bounds extent y.		fill normal: self bounds extent x @ 0.		fill radial: false.		z fillStyle: fill.		z borderColor: (z color alpha: 0).		self addMorph: z.	].	(randomplanet = 2) ifTrue: [		alto:= (Fondo alto / 3).		ancho:= (Fondo alto / 3).		self extent: (ancho @ alto).		self fillStyle isGradientFill ifTrue:[^self]. "Already done"		color1 := Color red darker darker darker darker darker darker darker darker darker darker darker.		color2 := Color purple darker darker darker darker darker darker darker.		fill := GradientFillStyle ramp: {0.0 -> color1. 1.0 -> color2}.		fill origin: self topLeft.		fill direction: 0 @ self bounds extent y.		fill normal: self bounds extent x @ 0.		fill radial: false.		self fillStyle: fill.		self borderColor: (self color alpha: 0).	].	(randomplanet = 3) ifTrue: [		alto:= (Fondo alto / 3).		ancho:= (Fondo alto / 3).		self extent: (ancho @ alto).		self fillStyle isGradientFill ifTrue:[^self]. "Already done"		color1 := Color lightYellow.		color2 := Color white.		fill := GradientFillStyle ramp: {0.0 -> color1. 1.0 -> color2}.		fill origin: self topLeft.		fill direction: 0 @ self bounds extent y.		fill normal: self bounds extent x @ 0.		fill radial: false.		self fillStyle: fill.		self borderColor: (self color alpha: 0).	].! !----SNAPSHOT----2023-11-26T10:31:43.724-03:00 23-11.image priorSource: 1263866!!Planeta methodsFor: 'as yet unclassified' stamp: 'Anonymous 11/26/2023 10:32' prior: 34818476!construirPlaneta	|y z randomplanet fill color1 color2|	randomplanet:= (3 to: 3) atRandom. "Elige un planeta de n planetas"	(randomplanet = 1) ifTrue: [		alto:= (Fondo alto / 3).		ancho:= (Fondo alto / 3) / 0.6.		self extent: (ancho * 0.6 @ alto).		color1 := Color lightOrange darker darker darker darker darker darker darker darker darker darker.		color2 := color1 darker darker darker darker.		fill := GradientFillStyle ramp: {0.0 -> color1. 1.0 -> color2}.		fill origin: self topLeft.		fill direction: 0 @ self bounds extent y.		fill normal: self bounds extent x @ 0.		fill radial: false.		self fillStyle: fill.		self borderColor: (self color alpha: 0).		y:= EllipseMorph new. "Anillo"		y extent: (ancho @ (self height / 3)).		y center: self center.		color1 := Color orange darker darker darker darker darker darker darker darker darker darker darker.		color2 := color1 darker.		fill := GradientFillStyle