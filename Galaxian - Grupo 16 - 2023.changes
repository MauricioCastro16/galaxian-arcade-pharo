607416!initialize	super initialize.	self startStepping.	self takeKeyboardFocus.	self mouseEnter: nil! !!Protagonista methodsFor: 'initialization' stamp: 'Anonymous 11/14/2023 17:32' prior: 33610514!initialize	super initialize.	self startStepping.	self takeKeyboardFocus.	self mouseEnter: true! !!Protagonista methodsFor: 'initialization' stamp: 'Anonymous 11/14/2023 17:33' prior: 33610711!initialize	super initialize.	self startStepping.	self takeKeyboardFocus.! !!Fondo methodsFor: 'initialization' stamp: 'Anonymous 11/14/2023 17:34' prior: 33588225!initialize	|prota|	super initialize. "inicializamos como forma"	self startStepping. "inicializamos los pasos"	ancho:= Display width.	alto:= Display height. "Le asignamos el tamaño de la ejecución del programa para que este no varíe durante la ejecución"	self extent: (ancho)@(alto).	self color: Color black.	prota:= Protagonista new.	prota position: (ancho/2)@(alto-(prota bottom * 1.1)).	self addMorph: prota.	prota takeKeyboardFocus.! !Protagonista removeSelector: #mouseLeave:!!Protagonista methodsFor: 'event handling' stamp: 'Anonymous 11/14/2023 17:35'!handleKeyPress: anEvent| keyValue |keyValue := anEvent keyValue.keyValue = 119ifTrue: [self position: self position - (0 @ 10)].keyValue = 115ifTrue: [self position: self position + (0 @ 10)].keyValue = 100ifTrue: [self position: self position + (10 @ 0)].keyValue = 97ifTrue: [self position: self position - (10 @ 0)]! !Protagonista removeSelector: #handleKeystroke:!!Protagonista methodsFor: 'event handling' stamp: 'Anonymous 11/14/2023 17:36'!handleKeyDown: anEvent| keyValue |keyValue := anEvent keyValue.keyValue = 119ifTrue: [self position: self position - (0 @ 10)].keyValue = 115ifTrue: [self position: self position + (0 @ 10)].keyValue = 100ifTrue: [self position: self position + (10 @ 0)].keyValue = 97ifTrue: [self position: self position - (10 @ 0)]! !!Fondo methodsFor: 'stepping and presenter' stamp: 'Anonymous 11/14/2023 17:39' prior: 33604424!step	|aux|	((1 to: 200) atRandom = 1) ifTrue: [ 		aux:= FiladeNaves new.		aux color: Color red. "Debug mode"		"aux color: (Color black alpha: 0)." "Official mode"		self addMorph: aux.		 ]! !!Fondo methodsFor: 'initialization' stamp: 'Anonymous 11/14/2023 17:40' prior: 33611077!initialize	|prota|	super initialize. "inicializamos como forma"	self startStepping. "inicializamos los pasos"	ancho:= Display width.	alto:= Display height. "Le asignamos el tamaño de la ejecución del programa para que este no varíe durante la ejecución"	self extent: (ancho)@(alto).	self color: Color black.	prota:= Protagonista new.	prota position: (ancho/2)@(alto-(prota bottom * 1.1)).	self addMorph: prota.! !!FiladeNaves methodsFor: 'initialization' stamp: 'Anonymous 11/14/2023 17:42' prior: 33606015!initialize	|aux|	super initialize.	self startStepping.	self extent: ((Fondo ancho - (2*(Fondo alto / 16)) @ (Fondo alto / 16))).	0 to: 14 do: [ :i|		aux:= Nave new.		aux position: (((((self width - aux width)/14)*i)+0.1)@0). "Acá se suma un mínimo en x porque sino se buguea el gráfico de la nave"		self addMorph: aux.		 ].! !!Protagonista methodsFor: 'initialization' stamp: 'Anonymous 11/14/2023 17:45' prior: 33610909!initialize	super initialize.	self startStepping.! !!Fondo methodsFor: 'initialization' stamp: 'Anonymous 11/14/2023 17:45' prior: 33612835!initialize	|prota|	super initialize. "inicializamos como forma"	self startStepping. "inicializamos los pasos"	ancho:= Display width.	alto:= Display height. "Le asignamos el tamaño de la ejecución del programa para que este no varíe durante la ejecución"	self extent: (ancho)@(alto).	self color: Color black.	prota:= Protagonista new.	prota position: (ancho/2)@(alto-(prota bottom * 1.1)).	self addMorph: prota.	prota takeKeyboardFocus! !!Fondo methodsFor: 'initialization' stamp: 'Anonymous 11/14/2023 17:46' prior: 33613936!initialize	|prota|	super initialize. "ini