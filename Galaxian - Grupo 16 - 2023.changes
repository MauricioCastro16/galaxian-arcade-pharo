(-1)) ifTrue: [ 		dash:= dash + 1.		self position: self position - (((self position x - ((self owner) left))abs / (Fondo ancho / 50)) @ 0).		 ].	(dash = 1 or: (dash = (-1))) ifTrue: [ self color: Color blue. dash:=0. invulnerable:=false. colorbase:= Color blue. lockmov:= false. ].	((1 to: 500) atRandom = 1) ifTrue: [ candash:= true. self submorphsDo: [ :i | i color: (i color alpha: 1) ] ]! !!Protagonista methodsFor: 'stepping and presenter' stamp: '3 11/18/2023 00:43' prior: 34106994!step	|explosion auxpos|	posx:= (self position) x. "Esta información le sirve a las naves enemigas para trackear a la nave protagonista"	(invulnerable) ifTrue: [ "Si está invulnerable, cada tiempo hay una probabilidad que deje de estarlo, además lo indica con un titileo"		(self color diff: Color black)<0.1 		ifTrue:[self color: colorbase] 		ifFalse:[self color:self color darker].		((1 to: 50) atRandom = 1) ifTrue: [ invulnerable := false. self color: Color blue ] "Saca la invulnerabilidad"						]ifFalse: [	(self owner) submorphsDo: [ :i | 		(i class = Enjambre) ifTrue: [ 			i submorphsDo: [:j | 				(j class = Nave) ifTrue: [				(self intersects: j bounds) ifTrue: [ "Detecta la interacción de una nave enemiga con la nave propia"					explosion:= Explosion new.					(self owner) addMorph: explosion.					explosion center: self center.					auxpos:= self position.					(j check) ifNotNil: [ j check delete ].					j delete.					self position: ((self owner) center x @ (self position y - (self owner height))). "En vez de destruir la nave, se recoloca en una posición fuera de la cámara, porque así no pierde el keyboardFocus"					(Instrucciones vidas > 0) ifTrue: [ self position: auxpos. Instrucciones vidas: (Instrucciones vidas - 1). invulnerable:= true]. "Si tiene más vidas, vuelve a spawnear"						]]]].		(i class = BalaEnemiga) ifTrue: [ "Detecta contacto con bala enemiga, idem anterior prácticamente"			(self intersects: i bounds) ifTrue: [					explosion:= Explosion 