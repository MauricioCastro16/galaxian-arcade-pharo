n:= 'izq' ]. "idem pero con la parte derecha del fondo"		(direccion = 'der') ifTrue: [ self position: (self position + (((self position x - ((self owner) right-self width))abs / (Fondo ancho / 40)) @ 0)) ]. "Mientras más cerca esté del borde, se mueva más lento"	(direccion = 'izq') ifTrue: [ self position: (self position - (((self position x - ((self owner) left))abs / (Fondo ancho / 40)) @ 0)) ]. "Idem pero para la izquierda"		(self submorphs = { }) ifTrue: [self delete. Fondo enjambremuerto: true. Instrucciones vidas: (Instrucciones vidas + 1)]. "Si no quedan naves, se da como enjambre muerto, se borra y avisa a Fondo. Además da una vida"		((1 to: 1+(((self submorphs) size)/2) abs) atRandom = 1) ifTrue: [ "Hace un random para entrar en la función de enojar naves enemigas"		self submorphsDo: [ :i | ((1 to: (1 + (self submorphs) size) ) atRandom = 1) ifTrue: [ "Random para c/u de las naves"				(i class = Nave) ifTrue: [ "Se aclara que sea una Nave porque puede haber checkpoints en el enjambre"				(i enojado or: (i reposicion)) ifFalse: [ "Para que no se enoje una nave que ya está enojado ni tampoco una nave que se está reposicionando"				i enojado: true.  "enoja"				aux:= Checkpoint new. "Este checkpoint crea un objeto invisible para que, cuando la nave baje por la pantalla, pueda volver a su lugar de origen"				aux position: i position.				aux extent: i extent. "Idem forma y posición de la nave saliente"				self addMorph: aux. "Lo añado al enjambre"				i check: aux. "Hace una agregación entre la nave y el checkpoint"				] ] ] ].		 ].	((1 to: 1+(((self submorphs) size)/8) abs) atRandom = 1) ifTrue: [ "Random para entrar al proceso de lanzar una bala"		self submorphsDo: [ :i | ((1 to: (1 + (((self submorphs) size)) abs )) atRandom = 1) ifTrue: [ "Random para que una nave tire una bala"				(i class = Nave) ifTrue: [ "Nuevamente se hace la comparación para que no sea un checkpoint"				((1 to: 5) atRandom = 1) ifTrue: [ bullet:= BalaEnemiga new. bullet position: i position. (self owner) addMorph: bullet ]. "Nuevo random para bajar la probabilidad de bala, se agrega la bala al fondo"				] ] ] ].	! !----SNAPSHOT----2023-11-21T01:10:09.869-03:00 18-11 ver2.image priorSource: 1016693!----SNAPSHOT----2023-11-21T01:10:43.407-03:00 18-11 ver2.image priorSource: 1019759!!Enjambre methodsFor: 'stepping and presenter' stamp: 'Anonymous 11/21/2023 01:11' prior: 34571312!step	|aux bullet correcty|		(posicionando) ifTrue: [		correcty:= ((((self owner) top + ((self height)/2))- self position y) / (Fondo ancho/30) ).		self position: self position + (0 @ correcty). "Corrige su posición respecto al checkpoint"		((self position y) truncated) = (((self owner) top + ((self height)/2)) truncated) ifTrue: [posicionando := false. mensaje delete] "Verifica que llegó a su posición"		].		(((self position x - (self owner) left))abs < (Fondo ancho / 20)) ifTrue: [ direccion:= 'der' ]. "compara posición del enjambre con la parte izquierda del fondo, y da un margen de error"	(((self position x - ((self owner) right - self width)))abs < (Fondo ancho / 20)) ifTrue: [ direccion:= 'izq' ]. "idem pero con la parte derecha del fondo"		(direccion = 'der') ifTrue: [ self position: (self position + (((self position x - ((self owner) right-self width))abs / (Fondo ancho / 40)) @ 0)) ]. "Mientras más cerca esté del borde, se mueva más lento"	(direccion = 'izq') ifTrue: [ self position: (self position - (((self position x - ((self owner) left))abs / (Fondo ancho / 40)) @ 0)) ]. "Idem pero para la izquierda"		(self submorphs = { }) ifTrue: [self delete. Fondo enjambremuerto: true. Instrucciones vidas: (Instrucciones vidas + 1). nroenjambre:= nroenjambre + 1]. "Si no quedan naves, se da como enjambre muerto, se borra y avisa a Fondo. Además da una vida y aumenta la cantidad del número de enjambre"		((1 to: 1+(((self submorphs) size)/2) abs) atRandom = 1) ifTrue: [ "Hace un random para entrar en la función de enojar naves enemigas"		self submorphsDo: [ :i | ((1 to: (1 + (self submorphs) size) ) atRandom = 1) ifTrue: [ "Random para c/u de las naves"				(i class = Nave) ifTrue: [ "Se aclara que sea una Nave porque puede haber checkpoints en el enjambre"				(i enojado or: (i reposicion)) ifFalse: [ "Para que no se enoje una nave que ya está enojado ni tampoco una nave que se está reposicionando"				i enojado: true.  "enoja"				aux:= Checkpoint new. "Este checkpoint crea un objeto invisible para que, cuando la nave baje por la pantalla, pueda volver a su lugar de origen"				aux position: i position.				aux extent: i extent. "Idem forma y posición de la nave saliente"				self addMorph: aux. "Lo añado al enjambre"				i check: aux. "Hace una agregación entre la nave y el checkpoint"				] ] ] ].		 ].	((1 to: 1+(((self submorphs) size)/8) abs) atRandom = 1) ifTrue: [ "Random para entrar al proceso de lanzar una bala"		self submorphsDo: [ :i | ((1 to: (1 + (((self submorphs) size)) abs )) atRandom = 1) ifTrue: [ "Random para que una nave tire una bala"				(i class = Nave) ifTrue: [ "Nuevamente se hace la comparación para que no sea un checkpoint"				((1 to: 5) atRandom = 1) ifTrue: [ bullet:= BalaEnemiga new. bullet position: i position. (self owner) addMorph: bullet ]. "Nuevo random para bajar la probabilidad de bala, se agrega la bala al fondo"				] ] ] ].	! !----SNAPSHOT----2023-11-21T01:11:33.308-03:00 18-11 ver2.image priorSource: 1019845!!Fondo methodsFor: 'initialization' stamp: 'Anonymous 11/21/2023 01:13' prior: 34570373!step	|enjambre texto|	(enjambremuerto) ifTrue: [ "Cuando muere un enjambre (todas sus naves) crea uno nuevo"		enjambremuerto:= false.		enjambre:= Enjambre new.		enjambre color: (Color black alpha: 0). 		enjambre center: (self topCenter - (enjambre height)).		self addMorph: enjambre behind: bordes.		( Estrella velocidad > 4) ifTrue: [ Estrella velocidad: (Estrella velocidad - 3) ].		( Nave velocidad > 26) ifTrue: [ Nave velocidad: (Nave veloci