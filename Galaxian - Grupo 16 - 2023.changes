21/2023 01:23' prior: 34589914!initialize	|planeta|	super initialize. "superinicializamos la forma"	self startStepping. "inicializamos los pasos"	enjambremuerto:= false.	nroenjambre := 0.	ancho:= Display height.	alto:= Display height. "Le asignamos el tamaño de la ejecución del programa para que este no varíe durante la ejecución"	self extent: (ancho)@(alto). "Tamaño del fondo"	self color: Color black.	self crearEstrellas. "Importa el orden para que las estrellas estén de fondo"	planeta:= Planeta new.	planeta center: self center.	self addMorph: planeta.	self bordes.	! !----SNAPSHOT----2023-11-21T01:23:24.91-03:00 18-11 ver2.image priorSource: 1043572!!Fondo methodsFor: 'stepping and presenter' stamp: 'Anonymous 11/21/2023 02:15' prior: 34579546!start	|score|	(self world) allMorphsDo: [ :i | (i class = Menu or: (i class = Nave or: (i class = Enjambre))) ifTrue: [ i delete ] ].	prota:= Protagonista new. "Nave principal"	prota center: self center.	prota color: (prota color alpha: 0).	self addMorph: prota.	score:= Score new. "puntaje"	score position: (self position).	self addMorph: score.	Estrella canAccelerate: true.	enjambremuerto:= true.! !----SNAPSHOT----2023-11-21T02:15:00.483-03:00 18-11 ver2.image priorSource: 1044314!!Fondo methodsFor: 'stepping and presenter' stamp: 'Anonymous 11/21/2023 02:15' prior: 34598929!start	|score|	(self world) allMorphsDo: [ :i | (i class = Menu or: (i class = Nave or: (i class = Enjambre or: (i class = Score)))) ifTrue: [ i delete ] ].	prota:= Protagonista new. "Nave principal"	prota center: self center.	prota color: (prota color alpha: 0).	self addMorph: prota.	score:= Score new. "puntaje"	score position: (self position).	self addMorph: score.	Estrella canAccelerate: true.	enjambremuerto:= true.! !----SNAPSHOT----2023-11-21T02:15:20.64-03:00 18-11 ver2.image priorSource: 1044910!!Protagonista methodsFor: 'stepping and presenter' stamp: 'Anonymous 11/21/2023 02:18' prior: 34479333!ste