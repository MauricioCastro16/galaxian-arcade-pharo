00:10:03.919-03:00 18-11.image priorSource: 622625!!Fondo methodsFor: 'initialization' stamp: 'Anonymous 11/19/2023 00:11' prior: 34160233!step	|enjambre|	self center: (Display width / 2) @ (Display height / 2).	(enjambremuerto) ifTrue: [ "Cuando muere un enjambre (todas sus naves) crea uno nuevo"		enjambremuerto:= false.		enjambre:= Enjambre new.		enjambre color: (Color black alpha: 0). 		enjambre position: (ancho/2)@((enjambre bottom /4)).		self addMorph: enjambre.		( Estrella velocidad > 4) ifTrue: [ Estrella velocidad: (Estrella velocidad - 3) ].		( Nave velocidad > 26) ifTrue: [ Nave velocidad: (Nave velocidad - 5)]. "Aumenta la dificultad en cada enjambre"	].	! !----SNAPSHOT----2023-11-19T00:11:32.841-03:00 18-11.image priorSource: 622705!SimpleButtonMorph subclass: #Botones	instanceVariableNames: '' 	classVariableNames: ''	package: 'Jueguito'!Morph subclass: #Menu	instanceVariableNames: 'menu dificultad'	classVariableNames: ''	package: 'Jueguito'!Morph subclass: #Menu	instanceVariableNames: 'menu dificultad nombre'	classVariableNames: ''	package: 'Jueguito'!Morph subclass: #Menu	instanceVariableNames: 'start dificultad nombre'	classVariableNames: ''	package: 'Jueguito'!!Menu methodsFor: 'as yet unclassified' stamp: 'Anonymous 11/19/2023 00:14'!initialize	 super initialize.    self extent:(200@200).    self color: (Color r:0.9  g:0.9  b:0.9).    nombre:= TextMorph new.    nombre contents: 'GALAXIAN'.    nombre center: self center - (0@40).    nombre color: Color black.    start:= Botones new.    start nombre: 'START'.    start center: self center.    dificultad:= Botones new.    dificultad nombre: 'Dificultad: FÁCIL'.    dificultad center: self center + (0@40).    self addMorph: dificultad.     self addMorph: start.    self addMorph: nombre.! !----SNAPSHOT----2023-11-19T00:14:19.439-03:00 18-11.image priorSource: 623425!!Menu methodsFor: 'initialization' stamp: 'Anonymous 11/19/2023 00:14' prior: 3417847