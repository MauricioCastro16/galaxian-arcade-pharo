miza de dónde sale la bala"		(randombala = 1) ifTrue: [bullet center: self center - (0@(self height*0.1))].		(randombala = 2) ifTrue: [bullet position: self position + ((self width * 0.3)@(self height*0.1))].		(randombala = 3) ifTrue: [bullet position: self position + ((self width * 0.7)@(self height*0.1))].		(self owner) addMorph: bullet. "Añade la bala al fondo"		bandBullet:= false "No permite que siga disparando"		] ].! !----SNAPSHOT----2023-11-18T00:52:39.974-03:00 17-11 ver2.image priorSource: 571752!!Protagonista methodsFor: 'event handling' stamp: '3 11/18/2023 00:52' prior: 34126358!handleKeyDown: anEvent| keyValue bullet randombala|keyValue := anEvent keyValue.Transcript show: keyValue.keyValue = 100 "Tecla D"ifTrue: [ (lockmov) ifFalse: [self position: self position + (((self position x - ((self owner) right-self width))abs / (Fondo ancho / 50)) @ 0)]]. "Movimiento relativo para la derecha"keyValue = 97 "Tecla A"ifTrue: [ (lockmov) ifFalse: [self position: self position - (((self position x - ((self owner) left))abs / (Fondo ancho / 50)) @ 0)]]. "Movimiento relativo para la izquierda"keyValue = 32 "Espacio"ifTrue: [ (bandBullet) ifTrue: [ "Se fija si puede disparar"		bullet:= Bala new. "Crea una nueva bala"		randombala:= (1 to: 3) atRandom. "Randomiza de dónde sale la bala"		(randombala = 1) ifTrue: [bullet center: self center - (0@(self height*0.1))].		(randombala = 2) ifTrue: [bullet position: self position + ((self width * 0.3)@(self height*0.1))].		(randombala = 3) ifTrue: [bullet position: self position + ((self width * 0.7)@(self height*0.1))].		(self owner) addMorph: bullet. "Añade la bala al fondo"		bandBullet:= false "No permite que siga disparando"		] ].keyValue = 101 "Dash, hacia la derecha"ifTrue: [ (candash and: (lockmov) not) ifTrue: [ "Se fija si puede dashear y si no tiene lockeado el movimiento"	colorbase:= Color lightGray. "Para que el titileo de la invulnerabilidad sea del color gris"	self color: Color lig