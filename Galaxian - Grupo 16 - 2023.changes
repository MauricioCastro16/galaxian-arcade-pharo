blecido"	(Estrella direccion = 'izquierda') ifTrue: [ self position: (self position - ((Fondo ancho / 100) @ 0)).].	(Estrella direccion = 'diagonal') ifTrue: [ self position: (self position + (0 @ (Fondo alto / 100))). self position: (self position - ((Fondo ancho / 100) @ 0)).].	((self center y) > (((self owner) bottom) + (alto / 2))) ifTrue: [ 		self position: (self position x) @ ((self owner) top - alto).		(visible) ifTrue: [ visible:= false. self color: (self color alpha: 0). self submorphsDo: [ :i | i color: (i color alpha: 0) ] ].		(((1 to: 100) atRandom = 1) and: (visible not)) ifTrue: [ visible:= true. self color: (self color alpha: 1). self submorphsDo: [ :i | i color: (i color alpha: 1) ] ].		]. 	((self center x) < ((self owner) left - (ancho/2))) ifTrue: [ 		self position: ((self owner) right) @ (self position y).		(visible) ifTrue: [ visible:= false. self color: (self color alpha: 0). self submorphsDo: [ :i | i color: (i color alpha: 0) ] ].		(((1 to: 100) atRandom = 1) and: (visible not)) ifTrue: [ visible:= true. self color: (self color alpha: 1). self submorphsDo: [ :i | i color: (i color alpha: 1) ] ].		]. "Si se sale de la pantalla, vuelve a una posición relativa tanto en x como en y"! !----SNAPSHOT----2023-11-19T13:43:41.772-03:00 18-11 ver2.image priorSource: 752529!----SNAPSHOT----2023-11-19T13:43:48.922-03:00 18-11 ver2.image priorSource: 754108!!Planeta methodsFor: 'stepping and presenter' stamp: 'Anonymous 11/19/2023 13:44' prior: 34307146!step	(Estrella direccion = 'abajo') ifTrue: [ self position: (self position + (0 @ (Fondo alto / 100))).]. "Según la dirección, se mueven para un lado establecido"	(Estrella direccion = 'izquierda') ifTrue: [ self position: (self position - ((Fondo ancho / 100) @ 0)).].	(Estrella direccion = 'diagonal') ifTrue: [ self position: (self position + (0 @ (Fondo alto / 100))). self position: (self position - ((Fondo ancho / 100) @ 0)).].	((self center y) > (((self owner) bottom) + (alto / 2))