sible para que, cuando la nave baje por la pantalla, pueda volver a su lugar de origen"				aux position: i position.				aux extent: i extent. "Idem forma y posición de la nave saliente"				self addMorph: aux. "Lo añado al enjambre"				i check: aux. "Hace una agregación entre la nave y el checkpoint"				] ] ] ].		 ].	((1 to: 1+(((self submorphs) size)/8) abs) atRandom = 1) ifTrue: [ "Random para entrar al proceso de lanzar una bala"		self submorphsDo: [ :i | ((1 to: (1 + (((self submorphs) size)) abs )) atRandom = 1) ifTrue: [ "Random para que una nave tire una bala"				(i class = Nave) ifTrue: [ "Nuevamente se hace la comparación para que no sea un checkpoint"				((1 to: 5) atRandom = 1) ifTrue: [ bullet:= BalaEnemiga new. bullet position: i position. (self owner) addMorph: bullet ]. "Nuevo random para bajar la probabilidad de bala, se agrega la bala al fondo"				] ] ] ].	! !----SNAPSHOT----2023-11-21T00:56:28.297-03:00 18-11 ver2.image priorSource: 1001373!----SNAPSHOT----2023-11-21T00:59:01.982-03:00 18-11 ver2.image priorSource: 1004423!Morph subclass: #Enjambre	instanceVariableNames: 'direccion posicionando nroenjambre'	classVariableNames: ''	package: 'Jueguito'!!Enjambre methodsFor: 'initialization' stamp: 'Anonymous 11/21/2023 01:00' prior: 34554554!initialize	|dir pArch line aux contx conty|	super initialize.	self startStepping.	self extent: (((Fondo ancho / 16)*10) @ ((Fondo alto / 24)*6)). "Setear tamaño para cualquier display"	direccion:= 'der'. "Arranca yendo para la derecha"	posicionando:= true.	nroenjambre:= 1.		"Abrir el documento de la configuración de las naves"	dir:= FileSystem disk workingDirectory.	pArch:= (dir,'\Naves.csv') readStream.	"config aleatoria"	((0 to: ((Instrucciones cantconfig)-1)) atRandom) timesRepeat: [ "Saltea las primeras n-1 configuraciones"		(7) timesRepeat: [ line:= pArch nextLine. ] 		].		conty:= -1.	(6) timesRepeat: [					line:= pArch nextLine.					conty:= conty + 1.					contx:= 