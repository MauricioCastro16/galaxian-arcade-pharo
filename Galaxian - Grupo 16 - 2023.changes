calBar := self bounds insetBy: (self width / 2.2) @ 12.aCanvas fillRectangle: verticalBar color: self color.! !----SNAPSHOT----2023-11-16T13:16:34.801-03:00 16-11.image priorSource: 150076!----SNAPSHOT----2023-11-16T13:17:34.742-03:00 16-11.image priorSource: 150385!!Protagonista methodsFor: 'as yet unclassified' stamp: 'Anonymous 11/16/2023 13:19'!drawOn: aCanvas| horizontalBar verticalBar|horizontalBar := self bounds insetBy: 1.5 @ (self height / 3).aCanvas fillRectangle: horizontalBar color: self color.horizontalBar := self bounds insetBy: 8 @ (self height / 2.3).aCanvas fillRectangle: horizontalBar color: Color white.verticalBar := self bounds insetBy: (self width / 3) @ 10.aCanvas fillRectangle: verticalBar color: self color.! !----SNAPSHOT----2023-11-16T13:19:37.824-03:00 16-11.image priorSource: 150465!----SNAPSHOT----2023-11-16T13:20:15.446-03:00 16-11.image priorSource: 151031!!Protagonista methodsFor: 'drawing' stamp: 'Anonymous 11/16/2023 13:20' prior: 33705063!drawOn: aCanvas| horizontalBar verticalBar|horizontalBar := self bounds insetBy: 1.5 @ (self height / 3).aCanvas fillRectangle: horizontalBar color: self color.verticalBar := self bounds insetBy: (self width / 2) @ 10.aCanvas fillRectangle: verticalBar color: self color.! !!Protagonista methodsFor: 'drawing' stamp: 'Anonymous 11/16/2023 13:20' prior: 33705713!drawOn: aCanvas| horizontalBar verticalBar|horizontalBar := self bounds insetBy: 1.5 @ (self height / 3).aCanvas fillRectangle: horizontalBar color: self color.verticalBar := self bounds insetBy: (self width / 2.1) @ 10.aCanvas fillRectangle: verticalBar color: self color.! !----SNAPSHOT----2023-11-16T13:20:39.999-03:00 16-11.image priorSource: 151111!----SNAPSHOT----2023-11-16T13:21:16.656-03:00 16-11.image priorSource: 151933!----SNAPSHOT----2023-11-16T13:21:43.168-03:00 16-11.image priorSource: 152013!!Protagonista methodsFor: 'drawing' stamp: 'Anonymous 11/16/2023 13:21' prior: 33706083!drawOn: aCanvas| horizontalBar verticalBar|horizontalBar := self bounds insetBy: 1.5 @ (self height / 3).aCanvas fillRectangle: horizontalBar color: self color.verticalBar := self bounds insetBy: (self width / 2.1) @ 10.aCanvas fillRectangle: verticalBar color: self color.! !!Protagonista methodsFor: 'drawing' stamp: 'Anonymous 11/16/2023 13:22' prior: 33706695!drawOn: aCanvas| horizontalBar verticalBar|horizontalBar := self bounds insetBy: 1.5 @ (self height / 3).aCanvas fillRectangle: horizontalBar color: self color.verticalBar := self bounds insetBy: (self width / 2.4) @ 10.aCanvas fillRectangle: verticalBar color: self color.! !----SNAPSHOT----2023-11-16T13:22:11.441-03:00 16-11.image priorSource: 152093!----SNAPSHOT----2023-11-16T13:27:36.467-03:00 16-11.image priorSource: 152917!!Fondo methodsFor: 'initialization' stamp: 'Anonymous 11/16/2023 13:30' prior: 33698862!initialize	|prota enjambre|	super initialize. "inicializamos como forma"	self startStepping. "inicializamos los pasos"	ancho:= Display height*1.5.	alto:= Display height. "Le asignamos el tamaño de la ejecución del programa para que este no varíe durante la ejecución"	self extent: (ancho)@(alto).	self color: Color black.	self crearEstrellas. "Importa el orden para que las estrellas estén de fondo"	prota:= Protagonista new.	prota position: (ancho/2)@(alto-(prota bottom * 2)).	self addMorph: prota.	enjambre:= Enjambre new.	enjambre color: (Color black alpha: 0). 	enjambre position: (ancho/2)@((enjambre bottom /4)).	self addMorph: enjambre.! !!Fondo methodsFor: 'initialization' stamp: 'Anonymous 11/16/2023 13:30' prior: 33707599!initialize	|prota enjambre|	super initialize. "inicializamos como forma"	self startStepping. "inicializamos los pasos"	ancho:= Display height*(4/3).	alto:= Display height. "Le asignamos el tamaño de la ejecución del programa para que este no varíe durante la ejecución"	self extent: (ancho)@(alto).	self color: Color black.	self crearEstrellas. "Importa el orden para que las estrellas estén de fondo"	prota:= Protagonista new.	prota position: (ancho/2)@(alto-(prota bottom * 2)).	self addMorph: prota.	enjambre:= Enjambre new.	enjambre color: (Color black alpha: 0). 	enjambre position: (ancho/2)@((enjambre bottom /4)).	self addMorph: enjambre.! !----SNAPSHOT----2023-11-16T13:30:44.503-03:00 16-11.image priorSource: 152997!!Fondo methodsFor: 'initialization' stamp: 'Anonymous 11/16/2023 13:31' prior: 33708356!initialize	|prota enjambre|	super initialize. "inicializamos como forma"	self startStepping. "inicializamos los pasos"	ancho:= Display height.	alto:= Display height. "Le asignamos el tamaño de la ejecución del programa para que este no varíe durante la ejecución"	self extent: (ancho)@(alto).	self color: Color black.	self crearEstrellas. "Importa el orden para que las estrellas estén de fondo"	prota:= Protagonista new.	prota position: (ancho/2)@(alto-(prota bottom * 2)).	self addMorph: prota.	enjambre:= Enjambre new.	enjambre color: (Color black alpha: 0). 	enjambre position: (ancho/2)@((enjambre bottom /4)).	self addMorph: enjambre.! !!Enjambre methodsFor: 'initialization' stamp: 'Anonymous 11/16/2023 13:31' prior: 33687693!initialize	|dir pArch line aux contx conty|	super initialize.	self startStepping.	self extent: (((Fondo ancho / 16)*10) @ ((Fondo alto / 24)*6)).		"Abrir un documento"	dir:= FileSystem disk workingDirectory.	pArch:= (dir,'\Naves.csv') readStream.	"config aleatoria"	((0 to: ((Instrucciones cantconfig)-1)) atRandom) timesRepeat: [ 		(7) timesRepeat: [ line:= pArch nextLine. ] 		].	conty:= -1.	(6) timesRepeat: [					line:= pArch nextLine.					conty:= conty + 1.					contx:= -1.					line do: [ :i| 						contx:= contx + 1.						aux:= Nave new.						aux position: (((Fondo alto / 16)*contx) @ ((aux height)*conty)).						self addMorph: aux.						(i = $■) ifTrue: [aux delete].						(i = $⌂) ifTrue: [aux color: Color blue].						(i = $○) ifTrue: [aux color: Color red].						(i = $▲) ifTrue: [aux color: Color pink].						(i = $☼) ifTrue: [aux color: Color green].								].					Transcript cr.					].				line:= pArch nextLine.				pArch close.! !Protagonista removeSelector: #drawOn:!----SNAPSHOT----2023-11-16T13:38:24.186-03:00 16-11.image priorSource: 154593!----SNAPSHOT----2023-11-16T13:38:58.747-03:00 16-11.image priorSource: 156546!----SNAPSHOT----2023-11-16T13:40:52.49-03:00 16-11.image priorSource: 156626!Bala removeSelector: #containsPoint:!Nave removeSelector: #containsPoint:!----SNAPSHOT----2023-11-16T13:41:34.691-03:00 16-11.image priorSource: 156706!----SNAPSHOT----2023-11-16T13:41:44.216-03:00 16-11.image priorSource: 156863!!Bala methodsFor: 'initialization' stamp: 'Anonymous 11/16/2023 13:42' prior: 33691698!step	self position: (self position - (0 @ 10)).	(self owner) submorphsDo: [ :i | 		(i class = Enjambre) ifTrue: [ 			i submorphsDo: [:j | 				(self intersects: j bounds) ifTrue: [ 					j delete. self delete. Protagonista bandBullet: true 					] 				] 			] 		].	(((self position) y) < (0)) ifTrue: [ self delete. Protagonista bandBullet: true ].		! !Object subclass: #Instrucciones	instanceVariableNames: ''	classVariableNames: 'cantconfig dificultad score'	package: 'Jueguito'!!Instrucciones class methodsFor: 'as yet unclassified' stamp: 'Anonymous 11/16/2023 13:43'!score: arg.	score := arg.! !!Instrucciones class methodsFor: 'accessing' stamp: 'Anonymous 11/16/2023 13:43'!score	^score! !!Bala methodsFor: 'initialization' stamp: 'Anonymous 11/16/2023 13:44' prior: 33711544!step	self position: (self position - (0 @ 10)).	(self owner) submorphsDo: [ :i | 		(i class = Enjambre) ifTrue: [ 			i submorphsDo: [:j | 				(self intersects: j bounds) ifTrue: [ 					(j color = Color blue) ifTrue: [ 						Instrucciones score: (Instrucciones score + 10)						 ].					(j color = Color red) ifTrue: [ 						Instrucciones score: (Instrucciones score + 20)