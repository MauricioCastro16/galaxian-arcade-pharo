----QUIT/NOSAVE----2023-11-26T14:44:03.816-03:00 Galaxian - Grupo 16 - 2023.image priorSource: 1275998!!GameOver methodsFor: 'as yet unclassified' stamp: 'Anonymous 11/26/2023 17:34' prior: 34740791!guardarScore	|dir pArch lectura line|	((texto contents) size > 3 or: ((texto contents) size < 1)) ifTrue: [ 																		error:= true.																		texto delete.																		texto:= TextMorph new.	 																	ingreso addMorph: texto.	 																	texto extent: (200@50).	 																	texto center: ingreso center.																		]																ifFalse: [ 																	nombre:=  (texto contents) asString asUppercase.																	"Abrir el documento para guardar los puntajes"																	dir:= FileSystem disk workingDirectory.																	lectura:= (dir,'\Score.csv') readStream.																	pArch:= (dir,'\Score.csv') writeStream.																	line:= ''.																	[lectura atEnd] whileFalse: [																		line:= line, lectura nextLine.																	].																	pArch nextPutAll: (line, nombre, ' ', Instrucciones score asString, ';').																	pArch close. 																	ingreso delete.																	anuncio delete.																	self mostrarScore.																	].! !!Protagonista methodsFor: 'initialization' stamp: 'Anonymous 11/26/2023 17:36' prior: 34669293!initialize	inicio:= true.	super initialize.	self startStepping.	self extent: (Fondo ancho) @ (Fondo alto).	posicionando:= true.	bandBullet:= true.	invulnerable:= true. "invulnerabilidad por un tiempo pequeño"	dash:= 0.	colorbase:= Color blue.	lockmov:= false.	fuego:= Morph new. "Este fuego representa el poder hacer un dash"	fuego extent: ((self extent)/6.1).	fuego color: (Color orange alpha: 0).	fuego center: self center.	fuego position: self position + ((self width*0.41)@(self height * 0.9)).	self addMorph: fuego.	candash:= true.	! !----QUIT----2023-11-26T19:59:25.785-03:00 Galaxian - Grupo 16 - 2023.image priorSource: 1275998!----QUIT----2023-11-26T22:42:29.053-03:00 Galaxian - Grupo 16 - 2023.image priorSource: 1278025!----QUIT----2023-11-26T22:43:39.608-03:00 Galaxian - Grupo 16 - 2023.image priorSource: 1278123!----QUIT----2023-11-26T23:52:39.439-03:00 Galaxian - Grupo 16 - 2023.image priorSource: 1278221!----QUIT----2023-11-27T00:08:53.433-03:00 Galaxian - Grupo 16 - 2023.image priorSource: 1278319!----QUIT/NOSAVE----2023-11-27T10:50:48.611-03:00 Galaxian - Grupo 16 - 2023.image priorSource: 1278417!----SNAPSHOT----2023-11-27T10:51:50.78-03:00 Galaxian - Grupo 16 - 2023.image priorSource: 1278417!----QUIT----2023-11-27T10:51:54.166-03:00 Galaxian - Grupo 16 - 2023.image priorSource: 1278620!----SNAPSHOT----2025-01-17T19:56:35.092-03:00 Galaxian - Grupo 16 - 2023.image priorSource: 1278721!----QUIT----2025-01-17T20:10:09.306-03:00 Galaxian - Grupo 16 - 2023.image priorSource: 1278819!----QUIT/NOSAVE----2025-01-17T20:11:12.457-03:00 Galaxian - Grupo 16 - 2023.image priorSource: 1278921!----SNAPSHOT----2025-02-04T21:15:08.929-03:00 Galaxian - Grupo 16 - 2023.image priorSource: 1278921!----SNAPSHOT----2025-02-04T21:17:35.172-03:00 Galaxian - Grupo 16 - 2023.image priorSource: 1279124!----SNAPSHOT----2025-02-04T21:34:41.586-03:00 Galaxian - Grupo 16 - 2023.image priorSource: 1279226!----QUIT----2025-02-04T21:34:43.409-03:00 Galaxian - Grupo 16 - 2023.image priorSource: 1279328!