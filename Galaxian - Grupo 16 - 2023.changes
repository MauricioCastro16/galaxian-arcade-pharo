ncated) ifTrue: [posicionando := false. mensaje delete] "Verifica que llegó a su posición"		].		(((self position x - (self owner) left))abs < (Fondo ancho / 20)) ifTrue: [ direccion:= 'der' ]. "compara posición del enjambre con la parte izquierda del fondo, y da un margen de error"	(((self position x - ((self owner) right - self width)))abs < (Fondo ancho / 20)) ifTrue: [ direccion:= 'izq' ]. "idem pero con la parte derecha del fondo"		(direccion = 'der') ifTrue: [ self position: (self position + (((self position x - ((self owner) right-self width))abs / (Fondo ancho / 40)) @ 0)) ]. "Mientras más cerca esté del borde, se mueva más lento"	(direccion = 'izq') ifTrue: [ self position: (self position - (((self position x - ((self owner) left))abs / (Fondo ancho / 40)) @ 0)) ]. "Idem pero para la izquierda"		(self submorphs = { }) ifTrue: [self delete. Fondo enjambremuerto: true. Instrucciones vidas: (Instrucciones vidas + 1).]. "Si no quedan naves, se da como enjambre muerto, se borra y avisa a Fondo. Además da una vida"		((1 to: 1+(((self submorphs) size)/2) abs) atRandom = 1) ifTrue: [ "Hace un random para entrar en la función de enojar naves enemigas"		self submorphsDo: [ :i | ((1 to: (1 + (self submorphs) size) ) atRandom = 1) ifTrue: [ "Random para c/u de las naves"				(i class = Nave) ifTrue: [ "Se aclara que sea una Nave porque puede haber checkpoints en el enjambre"				(i enojado or: (i reposicion)) ifFalse: [ "Para que no se enoje una nave que ya está enojado ni tampoco una nave que se está reposicionando"				i enojado: true.  "enoja"				aux:= Checkpoint new. "Este checkpoint crea un objeto invisible para que, cuando la nave baje por la pantalla, pueda volver a su lugar de origen"				aux position: i position.				aux extent: i extent. "Idem forma y posición de la nave saliente"				self addMorph: aux. "Lo añado al enjambre"				i check: aux. "Hace una agregación entre la nave y el checkpoint"				] ] ] ].		 ].	((1 to: 1+(((self submorphs) size)/8) abs) atRandom = 1) ifTrue: [ "Random para entrar al proceso de lanzar una bala"		self submorphsDo: [ :i | ((1 to: (1 + (((self submorphs) size)) abs )) atRandom = 1) ifTrue: [ "Random para que una nave tire una bala"				(i class = Nave) ifTrue: [ "Nuevamente se hace la comparación para que no sea un checkpoint"				((1 to: 5) atRandom = 1) ifTrue: [ bullet:= BalaEnemiga new. bullet position: i position. (self owner) addMorph: bullet ]. "Nuevo random para bajar la probabilidad de bala, se agrega la bala al fondo"				] ] ] ].	(((1 to: 10000) atRandom = 1) and: (velocidad > 10) ) ifTrue: [ velocidad:= velocidad + 1. ]	! !----SNAPSHOT----2023-11-23T00:03:20.232-03:00 22-11.image priorSource: 1130264!----SNAPSHOT----2023-11-23T00:03:22.651-03:00 22-11.image priorSource: 1134640!Morph subclass: #Enjambre	instanceVariableNames: 'direccion posicionando mensaje'	classVariableNames: 'velocidad'	package: 'Jueguito'!!Enjambre class methodsFor: 'as yet unclassified' stamp: 'Anonymous 11/23/2023 00:05'!velocidad	^velocidad! !!Enjambre class methodsFor: 'as yet unclassified' stamp: 'Anonymous 11/23/2023 00:06'!velocidad: arg	velocidad:= arg.! !----SNAPSHOT----2023-11-23T00:28:54.549-03:00 22-11.image priorSource: 1134721!----SNAPSHOT----2023-11-23T00:35:07.254-03:00 22-11.image priorSource: 1135176!----SNAPSHOT----2023-11-23T00:37:32.485-03:00 22-11.image priorSource: 1135257!----SNAPSHOT----2023-11-23T00:50:34.828-03:00 22-11.image priorSource: 1135338!----SNAPSHOT----2023-11-23T01:09:20.637-03:00 22-11.image priorSource: 1135419!----SNAPSHOT----2023-11-23T01:10:33.295-03:00 22-11.image priorSource: 1135500!----QUIT----2023-11-23T01:10:35.796-03:00 22-11.image priorSource: 1135581!----QUIT----2023-11-23T01:11:18.525-03:00 22-11.image priorSource: 1135662!----SNAPSHOT----2023-11-23T01:14:27.981-03:00 22-11.image priorSource: 1135739!----SNAPSHOT----2023-11-23T01:15:08.147-03:00 22-11.image priorSource: 1135816!----SNAPSHOT----2023-