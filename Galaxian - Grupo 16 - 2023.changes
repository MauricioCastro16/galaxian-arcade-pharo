ng]											ifFalse: [ posicion:= '0', i asString].									(7 - (((line at: i) substrings) at: 2) size) timesRepeat: [										auxnum:= auxnum, '0'										].									auxnum:= auxnum, (((line at: i) substrings) at: 2) asString.									score add: posicion, '- ', auxnum ,' - - - - ', (((line at: i) substrings) at: 1) asString 									].		 ].	puntajes:= TextMorph new.	puntajes contents: score.	self addMorph: puntajes.! !----SNAPSHOT----2023-11-23T13:53:00.791-03:00 22-11.image priorSource: 1191168!Morph subclass: #GameOver	instanceVariableNames: 'titulo continue texto ingreso anuncio nombre error score'	classVariableNames: ''	package: 'Jueguito'!!GameOver methodsFor: 'as yet unclassified' stamp: 'Anonymous 11/23/2023 13:54' prior: 34745779!mostrarScore |dir pArch line auxnum posicion|	"Abrir el documento para ver los puntajes"	dir:= FileSystem disk workingDirectory.	pArch:= (dir,'\Score.csv') readStream.	score:= OrderedCollection new.	line:= pArch nextLine.	(line) ifNil: [line:= ''] ifNotNil: [line:= line substrings: ';'].	(line) sort: [:a :b | (((a substrings) at: 2) asNumber) >= (((b substrings) at: 2) asNumber)].	1 to: 10 do: [ :i | 		(i > (line size)) ifTrue: [ 								(i = 10) ifTrue: [ posicion:= i asString]											ifFalse: [ posicion:= '0', i asString].								score add: posicion, '- 0000000 - - - - XXX' 								]								ifFalse: [									auxnum:= ''.									(i = 10) ifTrue: [ posicion:= i asString]											ifFalse: [ posicion:= '0', i asString].									(7 - (((line at: i) substrings) at: 2) size) timesRepeat: [										auxnum:= auxnum, '0'										].									auxnum:= auxnum, (((line at: i) substrings) at: 2) asString.									score add: posicion, '- ', auxnum ,' - - - - ', (((line at: i) substrings) at: 1) asString 									].		 ].	self addMorph: score.! !!GameOver methodsFor: 'as yet unclassified' stamp: 'Anonymous 11/23/2023 13:55' prior: 34747257!mostrarScore |dir pArch line auxnum posicion|	