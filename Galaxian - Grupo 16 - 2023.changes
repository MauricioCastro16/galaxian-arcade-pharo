 cr.					].				line:= pArch nextLine.				pArch close.! !!Enjambre methodsFor: 'initialization' stamp: 'Anonymous 11/15/2023 23:54' prior: 33675718!initialize	|dir pArch line aux contx conty|	super initialize.	self startStepping.	self extent: (((Fondo ancho / 16)*10) @ ((Fondo alto / 24)*6)).		"Abrir un documento"	dir:= FileSystem disk workingDirectory.	pArch:= (dir,'\Naves.csv') readStream.	"config aleatoria"	((0 to: ((Instrucciones cantconfig)-1)) atRandom) timesRepeat: [ 		(7) timesRepeat: [ line:= pArch nextLine. ] 		].	conty:= -1.	(6) timesRepeat: [					line:= pArch nextLine.					conty:= conty + 1.					contx:= -1.					line do: [ :i| 						contx:= contx + 1.						aux:= Nave new.						aux position: (((aux width)*contx) @ ((aux height)*conty)).						self addMorph: aux.						(i = $■) ifTrue: [aux delete].						(i = $⌂) ifTrue: ["nada"].						(i = $○) ifTrue: [aux color: Color red].						(i = $▲) ifTrue: [aux color: Color pink].						(i = $☼) ifTrue: [aux color: Color green].								].					Transcript cr.					].				line:= pArch nextLine.				pArch close.! !!Enjambre methodsFor: 'initialization' stamp: 'Anonymous 11/15/2023 23:54' prior: 33676785!initialize	|dir pArch line aux contx conty|	super initialize.	self startStepping.	self extent: (((Fondo ancho / 16)*10) @ ((Fondo alto / 24)*6)).		"Abrir un documento"	dir:= FileSystem disk workingDirectory.	pArch:= (dir,'\Naves.csv') readStream.	"config aleatoria"	((0 to: ((Instrucciones cantconfig)-1)) atRandom) timesRepeat: [ 		(7) timesRepeat: [ line:= pArch nextLine. ] 		].	conty:= -1.	(6) timesRepeat: [					line:= pArch nextLine.					conty:= conty + 1.					contx:= -1.					line do: [ :i| 						contx:= contx + 1.						aux:= Nave new.						aux position: (((Fondo alto / 20)*contx) @ ((aux height)*conty)).						self addMorph: aux.						(i = $■) ifTrue: [aux delete].						(i = $⌂) ifTrue: ["nada"].						(i = $○) ifTrue: [aux color: Color red].						(i = $▲) ifTr