"	headingText append: '	Vidas: '.	(Instrucciones vidas) timesRepeat: [headingText append: '▲']. "Muestra las vidas"	self contents: headingText. "Lo añade al morph"! !!Score methodsFor: 'initialization' stamp: 'Anonymous 11/19/2023 13:15' prior: 34260092!initialize	super initialize.	self backgroundColor: (Color black alpha: 0.8).	self color: Color white.! !!Score methodsFor: 'initialization' stamp: 'Anonymous 11/19/2023 13:16' prior: 34261543!initialize	super initialize.	self backgroundColor: (Color black alpha: 0.7).	self color: Color white.! !----SNAPSHOT----2023-11-19T13:17:53.252-03:00 18-11 ver2.image priorSource: 706164!!Planeta methodsFor: 'initialization' stamp: 'Anonymous 11/19/2023 13:18' prior: 34258546!initialize	|y z randomplanet fill color1 color2|	super initialize.	randomplanet:= (1 to: 1) atRandom.	(randomplanet = 1) ifTrue: [		alto:= (Fondo alto / 3).		ancho:= (Fondo alto / 3) / 0.6.		self extent: (ancho * 0.6 @ alto).		color1 := Color lightOrange darker darker darker darker darker darker darker darker darker darker darker.		color2 := color1 darker darker.		fill := GradientFillStyle ramp: {0.0 -> color1. 1.0 -> color2}.		fill origin: self topLeft.		fill direction: 0 @ self bounds extent y.		fill normal: self bounds extent x @ 0.		fill radial: false.		self fillStyle: fill.		self borderColor: (self color alpha: 0).		y:= EllipseMorph new. "Anillo"		y extent: (ancho @ (self height / 3)).		y center: self center.		y color: Color orange darker darker darker darker darker darker darker darker darker darker darker.		y borderColor: y color.		self addMorph: y.		z:= EllipseMorph new. "Superposición para que parezca un anillo"		z extent: ((self width / 1.052) @ (self height / 3)).		z center: self center - (0 @ (self height / 7.5)).		z color: self color.		z borderColor: z color.		self addMorph: z.	].	(randomplanet = 2) ifTrue: [		alto:= (Fondo alto / 3).		ancho:= (Fondo alto / 3).		self extent: (ancho @ alto).	