r,'\Naves.csv') readStream.	"config aleatoria"	((0 to: ((Instrucciones cantconfig)-1)) atRandom) timesRepeat: [ 		(7) timesRepeat: [ line:= pArch nextLine. ] 		].	conty:= -1.	(6) timesRepeat: [					line:= pArch nextLine.					conty:= conty + 1.					contx:= -1.					line do: [ :i| 						contx:= contx + 1.						aux:= Nave new.						aux position: (((Fondo alto / 16)*contx) @ ((aux height)*conty)).						self addMorph: aux.						(i = $■) ifTrue: [aux delete].						(i = $⌂) ifTrue: [aux color: Color blue].						(i = $○) ifTrue: [aux color: Color red].						(i = $▲) ifTrue: [aux color: Color pink].						(i = $☼) ifTrue: [aux color: Color green].								].					Transcript cr.					].				line:= pArch nextLine.				pArch close.! !----SNAPSHOT----2023-11-16T14:58:46.692-03:00 16-11.image priorSource: 191874!----QUIT----2023-11-16T14:59:35.203-03:00 16-11.image priorSource: 195077!----QUIT----2023-11-16T15:00:02.034-03:00 16-11.image priorSource: 195157!----QUIT----2023-11-16T15:01:42.686-03:00 16-11.image priorSource: 195233!----SNAPSHOT----2023-11-16T15:02:45.856-03:00 16-11 ver2.image priorSource: 195309!----QUIT----2023-11-16T15:02:48.202-03:00 16-11 ver2.image priorSource: 195385!----QUIT----2023-11-16T16:38:04.8-03:00 16-11 ver2.image priorSource: 195551!!Nave methodsFor: 'initialization' stamp: 'Anonymous 11/16/2023 16:44' prior: 33675436!initialize	super initialize.	self extent: ((Fondo ancho / 20) @ (Fondo alto / 24)).	! !----SNAPSHOT----2023-11-16T16:47:37.259-03:00 16-11 ver2.image priorSource: 195551!!Nave methodsFor: 'drawing' stamp: 'Anonymous 11/16/2023 16:49' prior: 33634743!drawOn: aCanvas| horizontalBar verticalBar|horizontalBar := self bounds insetBy: (self width / 5) @ (self height / 3).aCanvas fillRectangle: horizontalBar color: self color.horizontalBar := self bounds insetBy: 8 @ (self height / 2.3).aCanvas fillRectangle: horizontalBar color: Color white.verticalBar := self bounds insetBy: (self width / 3) @